/// This replaces the value behind the `v` unique reference by calling the
/// relevant function.
///
/// If a panic occurs in the `change` closure, the entire process will be aborted.
export template<typename T>
void take_mut(T& v, const auto& change) {
    replace(v, [&](auto&& value) { return std::make_tuple(change(std::move(value)), std::make_tuple()); });
}

/// This replaces the value behind the `v` unique reference by calling the
/// relevant function, and returns a result obtained along the way.
///
/// If a panic occurs in the `change` closure, the entire process will be aborted.
export template<typename T>
auto replace(T& v, const auto& change) {
    struct PanicGuard {
        mutable bool _rusty_forgotten = false;
        PanicGuard() = default;
        PanicGuard(const PanicGuard&) = default;
        PanicGuard(PanicGuard&& other) noexcept {
            this->_rusty_forgotten = other._rusty_forgotten;
            other._rusty_forgotten = true;
        }
        PanicGuard& operator=(const PanicGuard&) = default;
        PanicGuard& operator=(PanicGuard&& other) noexcept {
            if (this == &other) {
                return *this;
            }
            this->~PanicGuard();
            new (this) PanicGuard(std::move(other));
            return *this;
        }
        void rusty_mark_forgotten() const noexcept { _rusty_forgotten = true; }


        ~PanicGuard() noexcept(false) {
            if (_rusty_forgotten) { return; }
            rusty::intrinsics::abort();
        }
    };
    // Rust-only nested impl block skipped in local scope
    const auto guard = PanicGuard{};
    auto value = rusty::ptr::read(&v);
    auto&& [new_value, ret] = rusty::detail::deref_if_pointer_like(change(std::move(value)));
    // @unsafe
    {
        rusty::ptr::write(&v, std::move(new_value));
    }
    rusty::mem::forget(std::move(guard));
    return std::move(ret);
}

