export template<typename K, typename V, typename A>
    requires (rusty::alloc::Allocator<A> && std::copyable<A>)
struct Entry;
export template<typename K, typename V, typename A>
    requires (rusty::alloc::Allocator<A> && std::copyable<A>)
struct OccupiedError;

namespace core {
    namespace error {
    }
}

