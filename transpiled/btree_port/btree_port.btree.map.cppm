/// The error returned by [`try_insert`](BTreeMap::try_insert) when the key already exists.
///
/// Contains the occupied entry, and the value that was not inserted.
export template<typename K, typename V, typename A = rusty::alloc::Global>
    requires (rusty::alloc::Allocator<A> && std::copyable<A>)
struct OccupiedError {
    /// The entry in the map that was already occupied.
    OccupiedEntry<K, V, A> entry;
    /// The value which was not inserted, because the entry was already occupied.
