namespace {
class RawTableClone {
public:
    virtual ~RawTableClone() noexcept(false) {}
    virtual void clone_from_spec(const RawTableClone& source) = 0;
    RawTableClone(const RawTableClone&) = delete;
    RawTableClone& operator=(const RawTableClone&) = delete;
    RawTableClone(RawTableClone&&) = delete;
    RawTableClone& operator=(RawTableClone&&) = delete;
protected:
    RawTableClone() = default;
};
}

template <class U> class RawTableCloneAdapter;
template <class U> class RawTableCloneAdapterRef;
template <class U> class RawTableCloneAdapterRefMut;

/// Probe sequence based on triangular numbers, which is guaranteed (since our
/// table size is a power of two) to visit every group of elements exactly once.
///
/// A triangular probe has us jump by 1 more group every time. So first we
/// jump by 1 group (meaning we just continue our linear scan), then 2 groups
/// (skipping over 1 group), then 3 groups (skipping over 2 groups), and so on.
///
/// Proof that the probe will visit every group in the table:
/// <https://fgiesen.wordpress.com/2015/02/22/triangular-numbers-mod-2n/>
struct ProbeSeq {
    size_t pos;
    size_t stride;

    void move_next(size_t bucket_mask);

    ProbeSeq clone() const { return ProbeSeq{.pos = rusty::clone(this->pos), .stride = rusty::clone(this->stride)}; }
};

/// Helper which allows the max calculation for `ctrl_align` to be statically computed for each `T`
/// while keeping the rest of `calculate_layout_for` independent of `T`
struct TableLayout {
    size_t size;
    size_t ctrl_align;

    template<typename T>
    static constexpr TableLayout new_();
    rusty::Option<std::tuple<rusty::alloc::Layout, size_t>> calculate_layout_for(size_t buckets) const;

    // TODO: derive(Copy)
    TableLayout clone() const { return TableLayout{.size = rusty::clone(this->size), .ctrl_align = rusty::clone(this->ctrl_align)}; }
};

/// A reference to a hash table bucket containing a `T`.
///
/// This is usually just a pointer to the element itself. However if the element
/// is a ZST, then we instead track the index of the element in the table so
/// that `erase` works properly.
export template<typename T>
struct Bucket {
    rusty::ptr::NonNull<T> ptr;

    Bucket<T> clone() const {
        return Bucket<T>{.ptr = this->ptr};
    }
    static Bucket<T> from_base_index(rusty::ptr::NonNull<T> base, size_t index) {
        const auto ptr_shadow1 = ((std::is_empty_v<T>) ? reinterpret_cast<std::add_pointer_t<T>>(reinterpret_cast<uint8_t*>(static_cast<std::uintptr_t>(rusty::detail::deref_if_pointer_like(index)) + 1)) : rusty::ptr::sub(rusty::as_ptr(base), std::move(index)));
        return Bucket<T>{.ptr = rusty::ptr::NonNull<T>::new_unchecked(std::move(ptr_shadow1))};
    }
    size_t to_base_index(rusty::ptr::NonNull<T> base) const {
        if constexpr (std::is_empty_v<T>) {
            return (static_cast<size_t>(reinterpret_cast<std::uintptr_t>(rusty::as_ptr(this->ptr)))) - static_cast<size_t>(1);
        } else {
            // @unsafe
            {
                return offset_from<std::remove_pointer_t<std::remove_cvref_t<decltype((const_cast<std::add_pointer_t<std::add_const_t<T>>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<std::add_const_t<T>>>>(rusty::as_ptr(base)))))>>>(const_cast<std::add_pointer_t<std::add_const_t<T>>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<std::add_const_t<T>>>>(rusty::as_ptr(base))), const_cast<std::add_pointer_t<std::add_const_t<T>>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<std::add_const_t<T>>>>(rusty::as_ptr(this->ptr))));
            }
        }
    }
    std::add_pointer_t<T> as_ptr() const {
        if constexpr (std::is_empty_v<T>) {
            return reinterpret_cast<uint8_t*>(static_cast<std::uintptr_t>(rusty::mem::align_of<T>()));
        } else {
            // @unsafe
            {
                return rusty::ptr::sub(const_cast<std::add_pointer_t<T>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<T>>>(rusty::as_ptr(this->ptr))), 1);
            }
        }
    }
    rusty::ptr::NonNull<T> as_non_null() const {
        // @unsafe
        {
            return rusty::ptr::NonNull<T>::new_unchecked(rusty::as_ptr((*this)));
        }
    }
    Bucket<T> next_n(size_t offset) const {
        const auto ptr_shadow1 = ((std::is_empty_v<T>) ? reinterpret_cast<std::add_pointer_t<T>>(reinterpret_cast<uint8_t*>(static_cast<std::uintptr_t>((static_cast<size_t>(reinterpret_cast<std::uintptr_t>(rusty::as_ptr(this->ptr))))) + rusty::detail::deref_if_pointer_like(offset))) : rusty::ptr::sub(rusty::as_ptr(this->ptr), std::move(offset)));
        return Bucket<T>{.ptr = rusty::ptr::NonNull<T>::new_unchecked(std::move(ptr_shadow1))};
    }
    void drop() const {
        // @unsafe
        {
            std::destroy_at(rusty::as_ptr((*this)));
        }
    }
    T read() const {
        // @unsafe
        {
            return rusty::ptr::read(rusty::as_ptr((*this)));
        }
    }
    void write_(T val) const {
        // @unsafe
        {
            rusty::ptr::write(rusty::as_ptr((*this)), std::move(val));
        }
    }
    const T& as_ref() const {
        // @unsafe
        {
            return *rusty::as_ptr((*this));
        }
    }
    T& as_mut() const {
        // @unsafe
        {
            return *rusty::as_ptr((*this));
        }
    }
};

/// Iterator over a sub-range of a table. Unlike `RawIter` this iterator does
/// not track an item count.
export template<typename T>
struct RawIterRange {
    using Item = Bucket<T>;
    BitMaskIter current_group;
    Bucket<T> data;
    const uint8_t* next_ctrl;
    const uint8_t* end;

    static RawIterRange<T> new_(const uint8_t* ctrl, Bucket<T> data, size_t len) {
        // debug_assert: len != 0
        assert(true);  // assert((ctrl as size_t % Group :: WIDTH == 0));...
        auto end = rusty::ptr::add(ctrl, std::move(len));
        auto [current_group, next_ctrl] = rusty::detail::deref_if_pointer_like(std::make_tuple(Group::load_aligned(reinterpret_cast<const uint8_t*>(const_cast<Tag*>(reinterpret_cast<const Tag*>(ctrl)))).match_full(), rusty::ptr::add(ctrl, rusty::clone(rusty::clone(Group::WIDTH)))));
        return RawIterRange<T>{.current_group = BitMask{current_group._0}.into_iter(), .data = std::move(data), .next_ctrl = std::move(next_ctrl), .end = end};
    }
    std::tuple<RawIterRange<T>, rusty::Option<RawIterRange<T>>> split() {
        // @unsafe
        {
            if (this->end <= this->next_ctrl) {
                return std::make_tuple(std::move((*this)), rusty::Option<RawIterRange<T>>{rusty::None});
            } else {
                const auto len = offset_from<std::remove_pointer_t<std::remove_cvref_t<decltype((std::move(this->end)))>>>(std::move(this->end), std::move(this->next_ctrl));
        assert(true);  // assert((len % Group :: WIDTH == 0));...
                auto mid = ((rusty::detail::deref_if_pointer_like(len) / 2)) & ~(Group::WIDTH - static_cast<int32_t>(1));
                auto tail = RawIterRange<T>::new_(rusty::ptr::add(this->next_ctrl, std::move(mid)), this->data.next_n(Group::WIDTH).next_n(std::move(mid)), rusty::detail::deref_if_pointer_like(len) - rusty::detail::deref_if_pointer_like(mid));
        assert(true);  // assert((self . data . next_n (Group :: WIDTH) . next_n (mid)...
        assert(true);  // assert((self . end == tail . end));...
                this->end = rusty::ptr::add(this->next_ctrl, std::move(mid));
        assert(true);  // assert((self . end . add (Group :: WIDTH) == tail . next_ctr...
                return std::make_tuple(std::move((*this)), rusty::Option<RawIterRange<T>>(std::move(tail)));
            }
        }
    }
    template<bool DO_CHECK_PTR_RANGE>
    rusty::Option<Bucket<T>> next_impl() {
        while (true) {
            if (auto&& _iflet_scrutinee = this->current_group.next(); _iflet_scrutinee.is_some()) {
                decltype(auto) index = _iflet_scrutinee.unwrap();
                return rusty::Option<Bucket<T>>(this->data.next_n(std::move(index)));
            }
            if (rusty::detail::deref_if_pointer_like(DO_CHECK_PTR_RANGE) && (this->next_ctrl >= this->end)) {
                return rusty::Option<Bucket<T>>{rusty::None};
            }
            // @unsafe
            {
                this->current_group = BitMask{Group::load_aligned(reinterpret_cast<const uint8_t*>(const_cast<Tag*>(reinterpret_cast<const Tag*>(this->next_ctrl)))).match_full()._0}.into_iter();
                this->data = this->data.next_n(Group::WIDTH);
                this->next_ctrl = rusty::ptr::add(this->next_ctrl, rusty::clone(rusty::clone(Group::WIDTH)));
            }
        }
    }
    template<typename F, typename B>
    B fold_impl(size_t n, B acc, F f) {
        while (true) {
            while (true) {
                auto&& _whilelet = this->current_group.next();
                if (!(_whilelet.is_some())) { break; }
                auto index = _whilelet.unwrap();
                // debug_assert: rusty::detail::deref_if_pointer_like(n) != static_cast<size_t>(0)
                const auto bucket = this->data.next_n(std::move(index));
                acc = f(std::move(acc), std::move(bucket));
                n -= 1;
            }
            if (rusty::detail::deref_if_pointer_like(n) == static_cast<size_t>(0)) {
                return std::move(acc);
            }
            // @unsafe
            {
                this->current_group = BitMask{Group::load_aligned(reinterpret_cast<const uint8_t*>(const_cast<Tag*>(reinterpret_cast<const Tag*>(this->next_ctrl)))).match_full()._0}.into_iter();
                this->data = this->data.next_n(Group::WIDTH);
                this->next_ctrl = rusty::ptr::add(this->next_ctrl, rusty::clone(rusty::clone(Group::WIDTH)));
            }
        }
    }
    RawIterRange<T> clone() const {
        return RawIterRange<T>{.current_group = rusty::clone(this->current_group), .data = rusty::clone(this->data), .next_ctrl = this->next_ctrl, .end = this->end};
    }
    rusty::Option<Bucket<T>> next() {
        // @unsafe
        {
            return this->template next_impl<true>();
        }
    }
    std::tuple<size_t, rusty::Option<size_t>> size_hint() const {
        const auto remaining_buckets = (this->end > this->next_ctrl ? offset_from<std::remove_pointer_t<std::remove_cvref_t<decltype((this->end))>>>(this->end, this->next_ctrl) : 0);
        return std::make_tuple(static_cast<size_t>(0), rusty::Option<size_t>(Group::WIDTH + rusty::detail::deref_if_pointer_like(remaining_buckets)));
    }
};

/// Iterator which returns a raw pointer to every full bucket in the table.
///
/// For maximum flexibility this iterator is not bound by a lifetime, but you
/// must observe several rules when using it:
/// - You must not free the hash table while iterating (including via growing/shrinking).
/// - It is fine to erase a bucket that has been yielded by the iterator.
/// - Erasing a bucket that has not yet been yielded by the iterator may still
///   result in the iterator yielding that bucket (unless `reflect_remove` is called).
/// - It is unspecified whether an element inserted after the iterator was
///   created will be yielded by that iterator (unless `reflect_insert` is called).
/// - The order in which the iterator yields bucket is unspecified and may
///   change in the future.
export template<typename T>
struct RawIter {
    using Item = Bucket<T>;
    RawIterRange<T> iter;
    size_t items;

    void drop_elements() {
        // @unsafe
        {
            if ((!std::is_trivially_destructible_v<T>) && (rusty::detail::deref_if_pointer_like(this->items) != static_cast<size_t>(0))) {
                for (;;) {
                    auto __opt = this->iter.template next_impl<false>();
                    if (!__opt.is_some()) break;
                    auto item = __opt.unwrap();
                    item.drop();
                }
            }
        }
    }
    RawIter<T> clone() const {
        return RawIter<T>{.iter = rusty::clone(this->iter), .items = this->items};
    }
    static RawIter<T> default_() {
        // Empty iterator — `items = 0` short-circuits `next()`
        // before `iter` is ever touched.
        RawIter<T> r{};
        r.items = 0;
        return r;
    }
    rusty::Option<Bucket<T>> next() {
        if (rusty::detail::deref_if_pointer_like(this->items) == static_cast<size_t>(0)) {
            return rusty::Option<Bucket<T>>{rusty::None};
        }
        auto nxt = this->iter.template next_impl<false>();
        // debug_assert: nxt.is_some()
        this->items -= 1;
        return std::move(nxt);
    }
    std::tuple<size_t, rusty::Option<size_t>> size_hint() const {
        return std::make_tuple(this->items, rusty::Option<size_t>(this->items));
    }
    template<typename B, typename F>
    B fold(B init, F f) {
        // @unsafe
        {
            return this->iter.fold_impl(std::move(this->items), std::move(init), std::move(f));
        }
    }
};

// TODO(interface_traits): trait `SizedTypeProperties` has associated constants, not yet supported

/// Iterator which returns an index of every full bucket in the table.
///
/// For maximum flexibility this iterator is not bound by a lifetime, but you
/// must observe several rules when using it:
/// - You must not free the hash table while iterating (including via growing/shrinking).
/// - It is fine to erase a bucket that has been yielded by the iterator.
/// - Erasing a bucket that has not yet been yielded by the iterator may still
///   result in the iterator yielding index of that bucket.
/// - It is unspecified whether an element inserted after the iterator was
///   created will be yielded by that iterator.
/// - The order in which the iterator yields indices of the buckets is unspecified
///   and may change in the future.
export struct FullBucketsIndices {
    using Item = size_t;
    BitMaskIter current_group;
    size_t group_first_index;
    rusty::ptr::NonNull<uint8_t> ctrl;
    size_t items;

    static FullBucketsIndices default_();
    rusty::Option<size_t> next_impl();
    rusty::Option<size_t> next();
    std::tuple<size_t, rusty::Option<size_t>> size_hint() const;

    FullBucketsIndices clone() const { return FullBucketsIndices{.current_group = rusty::clone(this->current_group), .group_first_index = rusty::clone(this->group_first_index), .ctrl = rusty::clone(this->ctrl), .items = rusty::clone(this->items)}; }
};

/// Non-generic part of `RawTable` which allows functions to be instantiated only once regardless
/// of how many different key-value types are used.
struct RawTableInner {
    size_t bucket_mask;
    rusty::ptr::NonNull<uint8_t> ctrl_field;
    size_t growth_left;
    size_t items;

    static const RawTableInner NEW;
    static RawTableInner new_();
    template<typename A>
        requires (rusty::alloc::Allocator<A>)
    static auto new_uninitialized(const A& alloc, const auto& table_layout, size_t buckets, const auto& fallibility) -> rusty::Result<RawTableInner, rusty::collections::TryReserveError>;
    template<typename A>
        requires (rusty::alloc::Allocator<A>)
    static auto fallible_with_capacity(const A& alloc, const auto& table_layout, size_t capacity, const auto& fallibility) -> rusty::Result<RawTableInner, rusty::collections::TryReserveError>;
    template<typename A>
        requires (rusty::alloc::Allocator<A>)
    static RawTableInner with_capacity(const A& alloc, const auto& table_layout, size_t capacity);
    size_t fix_insert_index(size_t index) const;
    rusty::Option<size_t> find_insert_index_in_group(const Group& group, const ProbeSeq& probe_seq) const;
    template<typename Eq>
    rusty::Result<size_t, size_t> find_or_find_insert_index_inner(uint64_t hash, const Eq& eq) const;
    std::tuple<size_t, Tag> prepare_insert_index(uint64_t hash);
    size_t find_insert_index(uint64_t hash) const;
    template<typename Eq>
    rusty::Option<size_t> find_inner(uint64_t hash, const Eq& eq) const;
    void prepare_rehash_in_place();
    template<typename T>
    RawIter<T> iter() const;
    template<typename T>
    void drop_elements();
    template<typename T, typename A>
        requires (rusty::alloc::Allocator<A>)
    void drop_inner_table(const A& alloc, const auto& table_layout);
    template<typename T>
    Bucket<T> bucket(size_t index) const;
    uint8_t* bucket_ptr(size_t index, size_t size_of) const;
    template<typename T>
    rusty::ptr::NonNull<T> data_end() const;
    ProbeSeq probe_seq(uint64_t hash) const;
    void record_item_insert_at(size_t index, Tag old_ctrl, Tag new_ctrl);
    bool is_in_same_group(size_t i, size_t new_i, uint64_t hash) const;
    void set_ctrl_hash(size_t index, uint64_t hash);
    Tag replace_ctrl_hash(size_t index, uint64_t hash);
    void set_ctrl(size_t index, Tag ctrl);
    Tag* ctrl(size_t index) const;
    std::span<rusty::MaybeUninit<Tag>> ctrl_slice();
    size_t num_buckets() const;
    bool is_bucket_full(size_t index) const;
    size_t num_ctrl_bytes() const;
    bool is_empty_singleton() const;
    template<typename A>
        requires (rusty::alloc::Allocator<A>)
    auto prepare_resize(const A& alloc, const auto& table_layout, size_t capacity, const auto& fallibility) const -> rusty::Result<ScopeGuard<RawTableInner, std::function<void(RawTableInner&)>>, rusty::collections::TryReserveError>;
    template<typename A>
        requires (rusty::alloc::Allocator<A>)
    auto reserve_rehash_inner(const A& alloc, size_t additional, const std::function<uint64_t(RawTableInner&, size_t)>& hasher, const auto& fallibility, const auto& layout, rusty::Option<rusty::UnsafeFn<void(uint8_t*)>> drop) -> rusty::Result<rusty::Unit, rusty::collections::TryReserveError>;
    FullBucketsIndices full_buckets_indices() const;
    template<typename A>
        requires (rusty::alloc::Allocator<A>)
    auto resize_inner(const A& alloc, size_t capacity, const std::function<uint64_t(RawTableInner&, size_t)>& hasher, const auto& fallibility, const auto& layout) -> rusty::Result<rusty::Unit, rusty::collections::TryReserveError>;
    void rehash_in_place(const std::function<uint64_t(RawTableInner&, size_t)>& hasher, size_t size_of, rusty::Option<rusty::UnsafeFn<void(uint8_t*)>> drop);
    template<typename A>
        requires (rusty::alloc::Allocator<A>)
    void free_buckets(const A& alloc, const auto& table_layout);
    std::tuple<rusty::ptr::NonNull<uint8_t>, rusty::alloc::Layout> allocation_info(const auto& table_layout) const;
    size_t allocation_size_or_zero(const auto& table_layout) const;
    void clear_no_drop();
    void erase(size_t index);
};
inline const RawTableInner RawTableInner::NEW = RawTableInner::new_();

/// Iterator which consumes a table and returns elements.
export template<typename T, typename A = rusty::alloc::Global>
    requires (rusty::alloc::Allocator<A>)
struct RawIntoIter {
    using Item = T;
    RawIter<T> iter_field;
    rusty::Option<std::tuple<rusty::ptr::NonNull<uint8_t>, rusty::alloc::Layout, A>> allocation;
    rusty::PhantomData<T> marker;
    mutable bool _rusty_forgotten = false;
