FullBucketsIndices FullBucketsIndices::default_() {
    using Item = typename FullBucketsIndices::Item;
    // Empty iterator — items=0 short-circuits next().
    return FullBucketsIndices{
        .current_group = BitMaskIter{},
        .group_first_index = 0,
        .ctrl = rusty::ptr::NonNull<uint8_t>::new_unchecked(
            const_cast<uint8_t*>(reinterpret_cast<const uint8_t*>(
                rusty::as_ptr(Group::static_empty())))),
        .items = 0,
