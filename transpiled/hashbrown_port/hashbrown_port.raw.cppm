        if (likely(group.match_empty().any_bit_set())) {
            return rusty::Option<size_t>{rusty::None};
        }
        probe_seq.move_next(this->bucket_mask);
    }
}

void RawTableInner::prepare_rehash_in_place() {
    // @unsafe
    {
