void ProbeSeq::move_next(size_t bucket_mask) {
    if (!(rusty::detail::deref_if_pointer_like(this->stride) <= rusty::detail::deref_if_pointer_like(bucket_mask))) { throw std::logic_error("Went past end of probe sequence"); }
    this->stride += Group::WIDTH;
    this->pos += this->stride;
    this->pos &= bucket_mask;
}

