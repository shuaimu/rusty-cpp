        // debug_assert: this->is_bucket_full(std::move(index))
    }
    auto index_before = (static_cast<size_t>(index) - static_cast<size_t>(rusty::clone(rusty::clone(Group::WIDTH)))) & rusty::detail::deref_if_pointer_like(this->bucket_mask);
    auto [empty_before, empty_after] = rusty::detail::deref_if_pointer_like(std::make_tuple(Group::load(reinterpret_cast<const uint8_t*>(this->ctrl(std::move(index_before)))).match_empty(), Group::load(reinterpret_cast<const uint8_t*>(this->ctrl(std::move(index)))).match_empty()));
    auto ctrl = [&]() {
if (((empty_before).leading_zeros() + (empty_after).trailing_zeros()) >= rusty::clone(Group::WIDTH)) {
return rusty::clone(Tag::DELETED);
} else {
this->growth_left += 1;
return rusty::clone(Tag::EMPTY);
}
}();
    // @unsafe
    {
        this->set_ctrl(std::move(index), std::move(ctrl));
    }
    this->items -= 1;
}

RawIterHashIndices RawIterHashIndices::default_() {
    using Item = typename RawIterHashIndices::Item;
    // @unsafe
    {
        return RawIterHashIndices::new_(rusty::detail::deref_if_pointer_like(RawTableInner::new_()), static_cast<uint64_t>(0));
    }
}

RawIterHashIndices RawIterHashIndices::new_(const RawTableInner& table, uint64_t hash) {
    using Item = typename RawIterHashIndices::Item;
    auto tag_hash = Tag::full(std::move(hash));
    auto probe_seq = table.probe_seq(std::move(hash));
    auto group = Group::load(reinterpret_cast<const uint8_t*>(table.ctrl(std::move(probe_seq.pos))));
    auto bitmask = BitMask{group.match_tag(std::move(tag_hash))._0}.into_iter();
    return RawIterHashIndices{.bucket_mask = table.bucket_mask, .ctrl = table.ctrl_field, .tag_hash = std::move(tag_hash), .probe_seq = std::move(probe_seq), .group = std::move(group), .bitmask = std::move(bitmask)};
}

rusty::Option<size_t> RawIterHashIndices::next() {
    using Item = typename RawIterHashIndices::Item;
    // @unsafe
    {
        while (true) {
            if (auto&& _iflet_scrutinee = this->bitmask.next(); _iflet_scrutinee.is_some()) {
                decltype(auto) bit = _iflet_scrutinee.unwrap();
                auto index = ((rusty::detail::deref_if_pointer_like(this->probe_seq.pos) + rusty::detail::deref_if_pointer_like(bit))) & rusty::detail::deref_if_pointer_like(this->bucket_mask);
                return rusty::Option<size_t>(std::move(index));
            }
            if (likely(this->group.match_empty().any_bit_set())) {
                return rusty::Option<size_t>{rusty::None};
            }
            this->probe_seq.move_next(this->bucket_mask);
            auto index = this->probe_seq.pos;
            // debug_assert: rusty::detail::deref_if_pointer_like(index) < ((rusty::detail::deref_if_pointer_like(this->bucket_mask) + 1) + rusty::clone(Group::WIDTH))
            const auto group_ctrl = const_cast<Tag*>(reinterpret_cast<const Tag*>(rusty::ptr::add(rusty::as_ptr(this->ctrl), std::move(index))));
            this->group = Group::load(reinterpret_cast<const uint8_t*>(std::move(group_ctrl)));
            this->bitmask = BitMask{this->group.match_tag(this->tag_hash)._0}.into_iter();
        }
    }
}

} // namespace rusty::port::collections::hashbrown
