std::size_t index = 0;

rusty::Option<char32_t> next() {
if (index >= decoded.size()) {
return rusty::Option<char32_t>(rusty::None);
}
return rusty::Option<char32_t>(decoded[index++]);
}

template<typename Pred>
bool starts_with(Pred&& pred) const {
if (index >= decoded.size()) {
return false;
}
return static_cast<bool>(std::forward<Pred>(pred)(decoded[index]));
}

Chars as_str() const {
return *this;
}

Chars rev() const {
Chars out = *this;
std::reverse(out.decoded.begin(), out.decoded.end());
out.index = 0;
return out;
}

std::size_t count() const {
return decoded.size() - std::min(index, decoded.size());
}
};
