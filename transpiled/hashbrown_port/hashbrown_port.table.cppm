/// A view into an occupied entry in a `HashTable`.
/// It is part of the [`Entry`] enum.
///
/// # Examples
///
/// ```
/// # #[cfg(feature = "nightly")]
/// # fn test() {
/// use hashbrown::hash_table::{Entry, OccupiedEntry};
/// use hashbrown::{HashTable, DefaultHasher};
/// use std::hash::BuildHasher;
///
/// let mut table = HashTable::new();
/// let hasher = DefaultHasher::default();
/// let hasher = |val: &_| hasher.hash_one(val);
/// for x in ["a", "b", "c"] {
///     table.insert_unique(hasher(&x), x, hasher);
/// }
/// assert_eq!(table.len(), 3);
///
/// let _entry_o: OccupiedEntry<_, _> = table.find_entry(hasher(&"a"), |&x| x == "a").unwrap();
/// assert_eq!(table.len(), 3);
///
/// // Existing key
/// match table.entry(hasher(&"a"), |&x| x == "a", hasher) {
///     Entry::Vacant(_) => unreachable!(),
///     Entry::Occupied(view) => {
///         assert_eq!(view.get(), &"a");
///     }
/// }
///
/// assert_eq!(table.len(), 3);
///
/// // Existing key (take)
/// match table.entry(hasher(&"c"), |&x| x == "c", hasher) {
///     Entry::Vacant(_) => unreachable!(),
///     Entry::Occupied(view) => {
///         assert_eq!(view.remove().0, "c");
///     }
/// }
/// assert_eq!(table.find(hasher(&"c"), |&x| x == "c"), None);
/// assert_eq!(table.len(), 2);
/// # }
/// # fn main() {
/// #     #[cfg(feature = "nightly")]
/// #     test()
/// # }
/// ```
export template<typename T, typename A = rusty::alloc::Global>
    requires (rusty::alloc::Allocator<A>)
struct OccupiedEntry {
    Bucket<T> bucket;
    HashTable<T, A>& table;

    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.debug_struct("OccupiedEntry").field("value", this->get()).finish();
    }
    std::tuple<T, VacantEntry<T, A>> remove() {
        auto [val, index, tag] = rusty::detail::deref_if_pointer_like(this->table.raw.remove_tagged(std::move(this->bucket)));
        return std::make_tuple(std::move(val), VacantEntry<T, A>(std::move(tag), std::move(index), this->table));
    }
    const T& get() const {
        // @unsafe
        {
            return this->bucket.as_ref();
        }
    }
    T& get_mut() {
        // @unsafe
        {
            return this->bucket.as_mut();
        }
    }
    T& into_mut() {
        // @unsafe
        {
            return this->bucket.as_mut();
        }
    }
    HashTable<T, A>& into_table() {
        return this->table;
    }
    size_t bucket_index() const {
        // @unsafe
        {
            return this->table.raw.bucket_index(&this->bucket);
        }
    }
    template<typename F>
        requires (rusty::alloc::Allocator<A>)
    Entry<T, A> replace_entry_with(F f) {
        // @unsafe
        {
            return [&]() -> Entry<T, A> { auto&& _m = this->table.raw.replace_bucket_with(rusty::clone(this->bucket), std::move(f)); if (_m.is_none()) { return Entry<T, A>{Entry_Occupied<T, A>{std::move((*this))}}; } if (_m.is_some()) { auto&& _mv1 = _m.unwrap(); auto&& tag = rusty::detail::deref_if_pointer(_mv1); return Entry<T, A>{Entry_Vacant<T, A>{VacantEntry<T, A>(std::move(tag), this->bucket_index(), this->table)}}; } return [&]() -> Entry<T, A> { rusty::intrinsics::unreachable(); }(); }();
        }
    }
};

/// A view into a vacant entry in a `HashTable`.
/// It is part of the [`Entry`] enum.
///
/// # Examples
///
/// ```
/// # #[cfg(feature = "nightly")]
/// # fn test() {
/// use hashbrown::hash_table::{Entry, VacantEntry};
/// use hashbrown::{HashTable, DefaultHasher};
/// use std::hash::BuildHasher;
///
/// let mut table: HashTable<&str> = HashTable::new();
/// let hasher = DefaultHasher::default();
/// let hasher = |val: &_| hasher.hash_one(val);
///
/// let entry_v: VacantEntry<_, _> = match table.entry(hasher(&"a"), |&x| x == "a", hasher) {
///     Entry::Vacant(view) => view,
///     Entry::Occupied(_) => unreachable!(),
/// };
/// entry_v.insert("a");
/// assert!(table.find(hasher(&"a"), |&x| x == "a").is_some() && table.len() == 1);
///
/// // Nonexistent key (insert)
/// match table.entry(hasher(&"b"), |&x| x == "b", hasher) {
///     Entry::Vacant(view) => {
///         view.insert("b");
///     }
///     Entry::Occupied(_) => unreachable!(),
/// }
/// assert!(table.find(hasher(&"b"), |&x| x == "b").is_some() && table.len() == 2);
/// # }
/// # fn main() {
/// #     #[cfg(feature = "nightly")]
/// #     test()
/// # }
/// ```
export template<typename T, typename A = rusty::alloc::Global>
    requires (rusty::alloc::Allocator<A>)
struct VacantEntry {
    Tag tag;
    size_t index;
    HashTable<T, A>& table;

    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.write_str("VacantEntry");
    }
    OccupiedEntry<T, A> insert(T value) {
        auto bucket = this->table.raw.insert_tagged_at_index(std::move(this->tag), std::move(this->index), std::move(value));
        return OccupiedEntry<T, A>{.bucket = std::move(bucket), .table = this->table};
    }
    HashTable<T, A>& into_table() {
        return this->table;
    }
};

/// Type representing the absence of an entry, as returned by [`HashTable::find_entry`]
/// and [`HashTable::get_bucket_entry`].
///
/// This type only exists due to [limitations] in Rust's NLL borrow checker. In
/// the future, those methods will return an `Option<OccupiedEntry>` and this
/// type will be removed.
///
/// [limitations]: https://smallcultfollowing.com/babysteps/blog/2018/06/15/mir-based-borrow-check-nll-status-update/#polonius
///
/// # Examples
///
/// ```
/// # #[cfg(feature = "nightly")]
/// # fn test() {
/// use hashbrown::hash_table::{AbsentEntry, Entry};
/// use hashbrown::{HashTable, DefaultHasher};
/// use std::hash::BuildHasher;
///
/// let mut table: HashTable<&str> = HashTable::new();
/// let hasher = DefaultHasher::default();
/// let hasher = |val: &_| hasher.hash_one(val);
///
/// let entry_v: AbsentEntry<_, _> = table.find_entry(hasher(&"a"), |&x| x == "a").unwrap_err();
/// entry_v
///     .into_table()
///     .insert_unique(hasher(&"a"), "a", hasher);
/// assert!(table.find(hasher(&"a"), |&x| x == "a").is_some() && table.len() == 1);
///
/// // Nonexistent key (insert)
/// match table.entry(hasher(&"b"), |&x| x == "b", hasher) {
///     Entry::Vacant(view) => {
///         view.insert("b");
///     }
///     Entry::Occupied(_) => unreachable!(),
/// }
/// assert!(table.find(hasher(&"b"), |&x| x == "b").is_some() && table.len() == 2);
/// # }
/// # fn main() {
/// #     #[cfg(feature = "nightly")]
/// #     test()
/// # }
/// ```
export template<typename T, typename A = rusty::alloc::Global>
    requires (rusty::alloc::Allocator<A>)
struct AbsentEntry {
    HashTable<T, A>& table;

    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.write_str("AbsentEntry");
    }
    HashTable<T, A>& into_table() {
        return this->table;
    }
};

