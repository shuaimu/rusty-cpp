if constexpr (requires { s.is_some(); s.unwrap(); }) {
return s.is_some() ? std::string(s.unwrap()) : std::string();
} else {
return std::string(s);
}
} else if constexpr (requires { std::string_view(*value); }) {
return std::string(std::string_view(*value));
} else if constexpr (std::is_pointer_v<Value>) {
if (value == nullptr) {
return "<null>";
}
