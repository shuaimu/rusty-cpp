namespace {
template <class Owned>
class ToOwned {
public:
    virtual ~ToOwned() noexcept(false) {}
    virtual Owned to_owned() const = 0;
    virtual void clone_into(Owned& target) const = 0;
    ToOwned(const ToOwned&) = delete;
    ToOwned& operator=(const ToOwned&) = delete;
    ToOwned(ToOwned&&) = delete;
    ToOwned& operator=(ToOwned&&) = delete;
protected:
    ToOwned() = default;
};
}

