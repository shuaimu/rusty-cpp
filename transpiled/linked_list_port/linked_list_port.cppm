/// An iterator produced by calling `extract_if` on LinkedList.
export template<typename T, typename F, typename A = rusty::alloc::Global>
    requires (rusty::alloc::Allocator<A>)
struct ExtractIf {
    using Item = T;
    LinkedList<T, A>& list;
    rusty::Option<rusty::ptr::NonNull<Node<T>>> it;
    F pred;
    size_t idx;
    size_t old_len;

    rusty::Option<T> next() {
        while (true) {
            auto&& _whilelet = this->it;
            if (!(_whilelet.is_some())) { break; }
            auto node = _whilelet.unwrap();
            // @unsafe
            {
                this->it = node.as_ref().next;
                this->idx += 1;
                if ((this->pred)(rusty::addr_of_temp(node.as_mut().element))) {
                    this->list.unlink_node(std::move(node));
                    return rusty::Option<T>(rusty::Box<std::remove_cvref_t<decltype((rusty::as_ptr(node)))>>::from_raw(rusty::as_ptr(node)).element);
                }
            }
        }
        return rusty::Option<T>{rusty::None};
    }
    std::tuple<size_t, rusty::Option<size_t>> size_hint() const {
        return std::make_tuple(static_cast<size_t>(0), rusty::Option<size_t>(rusty::detail::deref_if_pointer_like(this->old_len) - rusty::detail::deref_if_pointer_like(this->idx)));
    }
    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        const auto peek = this->it.map([&](auto&& node) { return rusty::addr_of_temp(node.as_ref().element); });
        return f.debug_struct("ExtractIf").field("peek", peek).finish_non_exhaustive();
    }
};

void assert_covariance() {
    const rusty::SafeFn<LinkedList<std::string_view>(LinkedList<std::string_view>)> a = +[](LinkedList<std::string_view> x) -> LinkedList<std::string_view> {
        return std::move(x);
    };
    const rusty::SafeFn<Iter<std::string_view>(Iter<std::string_view>)> b = +[](Iter<std::string_view> x) -> Iter<std::string_view> {
        return std::move(x);
    };
    const rusty::SafeFn<IntoIter<std::string_view>(IntoIter<std::string_view>)> c = +[](IntoIter<std::string_view> x) -> IntoIter<std::string_view> {
        return std::move(x);
    };
}

