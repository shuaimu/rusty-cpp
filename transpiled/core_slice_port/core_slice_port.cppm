    virtual bool slice_contains(std::span<const SliceContains> x) const = 0;
    SliceContains(const SliceContains&) = delete;
    SliceContains& operator=(const SliceContains&) = delete;
    SliceContains(SliceContains&&) = delete;
    SliceContains& operator=(SliceContains&&) = delete;
