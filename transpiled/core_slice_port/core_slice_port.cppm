/// An iterator over subslices separated by elements that match a predicate
/// function.
///
/// This struct is created by the [`split`] method on [slices].
///
/// # Example
///
/// ```
/// let slice = [10, 40, 33, 20];
/// let mut iter = slice.split(|num| num % 3 == 0);
/// assert_eq!(iter.next(), Some(&[10, 40][..]));
/// assert_eq!(iter.next(), Some(&[20][..]));
/// assert_eq!(iter.next(), None);
/// ```
///
/// [`split`]: slice::split
/// [slices]: slice
export template<typename T, typename P>
struct Split {
    using Item = std::span<const T>;
    std::span<const T> v;
    P pred;
    bool finished;

    static Split<T, P> new_(std::span<const T> slice, P pred) {
        return Split<T, P>{.v = slice, .pred = std::move(pred), .finished = false};
    }
    std::span<const T> as_slice() const {
        if (this->finished) {
            return [&]() -> std::span<const T> { static const std::array<T, 0> _slice_ref_tmp = {}; return std::span<const T>(_slice_ref_tmp); }();
        } else {
            return this->v;
        }
    }
    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.debug_struct("Split").field("v", rusty::as_slice(this->v)).field("finished", &this->finished).finish();
    }
    Split<T, P> clone() const {
        return Split<T, P>{.v = this->v, .pred = rusty::clone(this->pred), .finished = this->finished};
    }
    rusty::Option<std::span<const T>> next() {
        if (this->finished) {
            return rusty::Option<std::span<const T>>{rusty::None};
        }
        return [&]() -> rusty::Option<std::span<const T>> { auto&& _m = rusty::iter(this->v).position([&](auto&& x) { return (this->pred)(std::move(x)); }); if (_m.is_none()) { return this->finish(); } if (_m.is_some()) { auto&& _mv1 = _m.unwrap(); auto&& idx = rusty::detail::deref_if_pointer(_mv1); return [&]() -> rusty::Option<std::span<const T>> { auto [left, right] = rusty::detail::deref_if_pointer_like(std::make_tuple(rusty::slice_to(this->v, idx), rusty::slice_from(this->v, rusty::detail::deref_if_pointer_like(idx) + 1)));
auto ret = rusty::Some(std::move(left));
this->v = std::move(right);
return std::move(ret); }(); } return [&]() -> rusty::Option<std::span<const T>> { rusty::intrinsics::unreachable(); }(); }();
    }
    std::tuple<size_t, rusty::Option<size_t>> size_hint() const {
        if (this->finished) {
            return std::make_tuple(static_cast<size_t>(0), rusty::Option<size_t>(static_cast<size_t>(0)));
        } else {
            return std::make_tuple(static_cast<size_t>(1), rusty::Option<size_t>(rusty::len(this->v) + static_cast<size_t>(1)));
        }
    }
    rusty::Option<std::span<const T>> next_back() {
        if (this->finished) {
            return rusty::Option<std::span<const T>>{rusty::None};
        }
        return [&]() -> rusty::Option<std::span<const T>> { auto&& _m = rusty::iter(this->v).rposition([&](auto&& x) { return (this->pred)(std::move(x)); }); if (_m.is_none()) { return this->finish(); } if (_m.is_some()) { auto&& _mv1 = _m.unwrap(); auto&& idx = rusty::detail::deref_if_pointer(_mv1); return [&]() -> rusty::Option<std::span<const T>> { auto [left, right] = rusty::detail::deref_if_pointer_like(std::make_tuple(rusty::slice_to(this->v, idx), rusty::slice_from(this->v, rusty::detail::deref_if_pointer_like(idx) + 1)));
auto ret = rusty::Some(std::move(right));
this->v = std::move(left);
return std::move(ret); }(); } return [&]() -> rusty::Option<std::span<const T>> { rusty::intrinsics::unreachable(); }(); }();
    }
    rusty::Option<std::span<const T>> finish() {
        if (this->finished) {
            return rusty::Option<std::span<const T>>{rusty::None};
        } else {
            this->finished = true;
            return rusty::Option<std::span<const T>>(this->v);
        }
    }
};

/// An iterator over subslices separated by elements that match a predicate
/// function. Unlike `Split`, it contains the matched part as a terminator
/// of the subslice.
///
/// This struct is created by the [`split_inclusive`] method on [slices].
///
/// # Example
///
/// ```
/// let slice = [10, 40, 33, 20];
/// let mut iter = slice.split_inclusive(|num| num % 3 == 0);
/// assert_eq!(iter.next(), Some(&[10, 40, 33][..]));
/// assert_eq!(iter.next(), Some(&[20][..]));
/// assert_eq!(iter.next(), None);
/// ```
///
/// [`split_inclusive`]: slice::split_inclusive
/// [slices]: slice
export template<typename T, typename P>
struct SplitInclusive {
    using Item = std::span<const T>;
    std::span<const T> v;
    P pred;
    bool finished;

    static SplitInclusive<T, P> new_(std::span<const T> slice, P pred) {
        auto finished = rusty::is_empty(slice);
        return SplitInclusive<T, P>{.v = slice, .pred = std::move(pred), .finished = std::move(finished)};
    }
    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.debug_struct("SplitInclusive").field("v", rusty::as_slice(this->v)).field("finished", &this->finished).finish();
    }
    SplitInclusive<T, P> clone() const {
        return SplitInclusive<T, P>{.v = this->v, .pred = rusty::clone(this->pred), .finished = this->finished};
    }
    rusty::Option<std::span<const T>> next() {
        if (this->finished) {
            return rusty::Option<std::span<const T>>{rusty::None};
        }
        const auto idx_self_ref_tmp = rusty::map(rusty::iter(this->v).position([&](auto&& x) { return (this->pred)(std::move(x)); }), [&](auto&& idx) { return rusty::detail::deref_if_pointer_like(idx) + 1; }).unwrap_or(rusty::len(this->v));
        const auto idx = std::move(idx_self_ref_tmp);
        if (rusty::detail::deref_if_pointer_like(idx) == rusty::len(this->v)) {
            this->finished = true;
        }
        auto ret = rusty::Option<const T&>(rusty::slice_to(this->v, idx));
        this->v = rusty::slice_from(this->v, idx);
        return std::move(ret);
    }
    std::tuple<size_t, rusty::Option<size_t>> size_hint() const {
        if (this->finished) {
            return std::make_tuple(static_cast<size_t>(0), rusty::Option<size_t>(static_cast<size_t>(0)));
        } else {
            return std::make_tuple(static_cast<size_t>(1), rusty::Option<size_t>(rusty::cmp::max(1, rusty::len(this->v))));
        }
    }
    rusty::Option<std::span<const T>> next_back() {
        if (this->finished) {
            return rusty::Option<std::span<const T>>{rusty::None};
        }
        const auto remainder = (rusty::is_empty(this->v) ? rusty::addr_of_temp(std::array<int, 0>{}) : rusty::slice_to(this->v, (rusty::len(this->v) - 1)));
        const auto idx_self_ref_tmp = rusty::map(rusty::iter(remainder).rposition([&](auto&& x) { return (this->pred)(std::move(x)); }), [&](auto&& idx) { return rusty::detail::deref_if_pointer_like(idx) + 1; }).unwrap_or(0);
        const auto idx = std::move(idx_self_ref_tmp);
        if (rusty::detail::deref_if_pointer_like(idx) == 0) {
            this->finished = true;
        }
        auto ret = rusty::Option<const T&>(rusty::slice_from(this->v, idx));
        this->v = rusty::slice_to(this->v, idx);
        return std::move(ret);
    }
};

/// An iterator over the mutable subslices of the vector which are separated
/// by elements that match `pred`.
///
/// This struct is created by the [`split_mut`] method on [slices].
///
/// # Example
///
/// ```
/// let mut v = [10, 40, 30, 20, 60, 50];
/// let iter = v.split_mut(|num| *num % 3 == 0);
/// ```
///
/// [`split_mut`]: slice::split_mut
/// [slices]: slice
export template<typename T, typename P>
struct SplitMut {
    using Item = std::span<T>;
    std::span<T> v;
    P pred;
    bool finished;

    static SplitMut<T, P> new_(std::span<T> slice, P pred) {
        return SplitMut<T, P>{.v = slice, .pred = std::move(pred), .finished = false};
    }
    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.debug_struct("SplitMut").field("v", rusty::as_slice(this->v)).field("finished", &this->finished).finish();
    }
    rusty::Option<std::span<T>> finish() {
        if (this->finished) {
            return rusty::Option<std::span<T>>{rusty::None};
        } else {
            this->finished = true;
            return rusty::Option<std::span<T>>(mem::take(this->v));
        }
    }
    rusty::Option<std::span<T>> next() {
        if (this->finished) {
            return rusty::Option<std::span<T>>{rusty::None};
        }
        return [&]() -> rusty::Option<std::span<T>> { auto&& _m = rusty::iter(this->v).position([&](auto&& x) { return (this->pred)(std::move(x)); }); if (_m.is_none()) { return this->finish(); } if (_m.is_some()) { auto&& _mv1 = _m.unwrap(); auto&& idx = rusty::detail::deref_if_pointer(_mv1); return [&]() -> rusty::Option<std::span<T>> { const auto tmp = mem::take(this->v);
auto [head, tail] = rusty::detail::deref_if_pointer_like(tmp.split_at_mut(rusty::detail::deref_if_pointer_like(idx) + static_cast<size_t>(1)));
this->v = std::move(tail);
return rusty::Option<std::span<T>>(rusty::slice_to(head, idx)); }(); } return [&]() -> rusty::Option<std::span<T>> { rusty::intrinsics::unreachable(); }(); }();
    }
    std::tuple<size_t, rusty::Option<size_t>> size_hint() const {
        if (this->finished) {
            return std::make_tuple(static_cast<size_t>(0), rusty::Option<size_t>(static_cast<size_t>(0)));
        } else {
            return std::make_tuple(static_cast<size_t>(1), rusty::Option<size_t>(rusty::len(this->v) + static_cast<size_t>(1)));
        }
    }
    rusty::Option<std::span<T>> next_back() {
        if (this->finished) {
            return rusty::Option<std::span<T>>{rusty::None};
        }
        const auto idx_opt = [&]() { auto& pred = this->pred;
return rusty::iter(this->v).rposition([&](auto&& x) { return (pred)(std::move(x)); }); }();
        return [&]() -> rusty::Option<std::span<T>> { auto&& _m = idx_opt; if (_m.is_none()) { return this->finish(); } if (_m.is_some()) { auto&& _mv1 = _m.unwrap(); auto&& idx = rusty::detail::deref_if_pointer(_mv1); return [&]() -> rusty::Option<std::span<T>> { const auto tmp = mem::take(this->v);
auto [head, tail] = rusty::detail::deref_if_pointer_like(tmp.split_at_mut(idx));
this->v = std::move(head);
return rusty::Option<std::span<T>>(rusty::slice_from(tail, 1)); }(); } return [&]() -> rusty::Option<std::span<T>> { rusty::intrinsics::unreachable(); }(); }();
    }
};

/// An iterator over the mutable subslices of the vector which are separated
/// by elements that match `pred`. Unlike `SplitMut`, it contains the matched
/// parts in the ends of the subslices.
///
/// This struct is created by the [`split_inclusive_mut`] method on [slices].
///
/// # Example
///
/// ```
/// let mut v = [10, 40, 30, 20, 60, 50];
/// let iter = v.split_inclusive_mut(|num| *num % 3 == 0);
/// ```
///
/// [`split_inclusive_mut`]: slice::split_inclusive_mut
/// [slices]: slice
export template<typename T, typename P>
struct SplitInclusiveMut {
    using Item = std::span<T>;
    std::span<T> v;
    P pred;
    bool finished;

    static SplitInclusiveMut<T, P> new_(std::span<T> slice, P pred) {
        auto finished = rusty::is_empty(slice);
        return SplitInclusiveMut<T, P>{.v = slice, .pred = std::move(pred), .finished = std::move(finished)};
    }
    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.debug_struct("SplitInclusiveMut").field("v", rusty::as_slice(this->v)).field("finished", &this->finished).finish();
    }
    rusty::Option<std::span<T>> next() {
        if (this->finished) {
            return rusty::Option<std::span<T>>{rusty::None};
        }
        auto idx_opt = [&]() { auto& pred = this->pred;
