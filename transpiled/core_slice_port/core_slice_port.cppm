// Extension trait SliceIndex lowered to rusty_ext:: free functions
namespace rusty_ext {
    export template<typename T>
    rusty::Option<const T&> get(size_t self_, std::span<const T> slice) {
        using Self = std::remove_reference_t<decltype(self_)>;
        if (rusty::detail::deref_if_pointer_like(self_) < rusty::len(slice)) {
            // @unsafe
            {
                return rusty::Some(slice_get_unchecked(slice, std::move(self_)));
            }
        } else {
            return rusty::Option<const T&>{rusty::None};
        }
    }

    export template<typename T>
    rusty::Option<T&> get_mut(size_t self_, std::span<T> slice) {
        using Self = std::remove_reference_t<decltype(self_)>;
        if (rusty::detail::deref_if_pointer_like(self_) < rusty::len(slice)) {
            // @unsafe
            {
