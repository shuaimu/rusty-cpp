template<typename A, typename B, typename C>
rusty::ops::ControlFlow<B, C> chaining_impl(std::span<const A> left, std::span<const A> right, const auto& elem_chain, const auto& len_chain) {
    const auto l = rusty::cmp::min(rusty::len(left), rusty::len(right));
    const auto lhs = rusty::slice_to(left, l);
    const auto rhs = rusty::slice_to(right, l);
    for (auto&& i : rusty::for_in(rusty::range(0, l))) {
        RUSTY_TRY(elem_chain(&lhs[i], &rhs[i]));
    }
    return len_chain(rusty::len(left), rusty::len(right));
