class SplitIter {
public:
    virtual ~SplitIter() noexcept(false) {}
    // TODO(interface_traits): method `finish` uses unresolved Self/auto in signature, not yet supported
    SplitIter(const SplitIter&) = delete;
    SplitIter& operator=(const SplitIter&) = delete;
    SplitIter(SplitIter&&) = delete;
    SplitIter& operator=(SplitIter&&) = delete;
protected:
    SplitIter() = default;
};

