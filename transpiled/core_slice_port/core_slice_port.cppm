}
} else if constexpr (requires { value.bits(); }) {
using Bits = std::remove_cv_t<std::remove_reference_t<decltype(value.bits())>>;
if constexpr (std::is_integral_v<Bits> && !std::is_same_v<Bits, bool>) {
