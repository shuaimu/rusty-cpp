enum class Direction {
    Front,
    Back
};
inline constexpr Direction Direction_Front() { return Direction::Front; }
inline constexpr Direction Direction_Back() { return Direction::Back; }

export enum class GetDisjointMutError {
    IndexOutOfBounds,
    OverlappingIndices
};
inline constexpr GetDisjointMutError GetDisjointMutError_IndexOutOfBounds() { return GetDisjointMutError::IndexOutOfBounds; }
inline constexpr GetDisjointMutError GetDisjointMutError_OverlappingIndices() { return GetDisjointMutError::OverlappingIndices; }
inline rusty::fmt::Result rusty_fmt(const GetDisjointMutError& self, rusty::fmt::Formatter& f) {
    const auto msg = [&]() -> std::string_view { auto&& _m = self; if (_m == GetDisjointMutError::IndexOutOfBounds) return std::string_view("an index is out of bounds");
if (_m == GetDisjointMutError::OverlappingIndices) return std::string_view("there were overlapping indices"); }();
    return rusty::write_fmt(f, rusty::to_string(msg));
}

