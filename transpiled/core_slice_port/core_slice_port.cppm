/// ASCII test *without* the chunk-at-a-time optimizations.
///
/// This is carefully structured to produce nice small code -- it's smaller in
/// `-O` than what the "obvious" ways produces under `-C opt-level=s`.  If you
/// touch it, be sure to run (and update if needed) the assembly test.
export bool is_ascii_simple(std::span<const uint8_t> bytes) {
    while (true) {
        auto&& _whilelet = bytes;
        if (!(rusty::len(rusty::detail::deref_if_pointer(_whilelet)) >= 1)) { break; }
        auto&& rest = rusty::detail::deref_if_pointer(rusty::slice(rusty::detail::deref_if_pointer(_whilelet), 0, (rusty::len(rusty::detail::deref_if_pointer(_whilelet)) - 1)));
        auto&& last = rusty::detail::deref_if_pointer(rusty::detail::deref_if_pointer(_whilelet)[(rusty::len(rusty::detail::deref_if_pointer(_whilelet)) - 1)]);
        if (!last.is_ascii()) {
            break;
        }
        bytes = std::move(rest);
    }
    return rusty::is_empty(bytes);
}

/// Optimized ASCII test that will use usize-at-a-time operations instead of
/// byte-at-a-time operations (when possible).
///
/// The algorithm we use here is pretty simple. If `s` is too short, we just
/// check each byte and be done with it. Otherwise:
///
/// - Read the first word with an unaligned load.
/// - Align the pointer, read subsequent words until end with aligned loads.
/// - Read the last `usize` from `s` with an unaligned load.
///
/// If any of these loads produces something for which `contains_nonascii`
/// (above) returns true, then we know the answer is false.
bool is_ascii(std::span<const uint8_t> s) {
    std::make_tuple();
}

bool is_ascii_sse2(std::span<const uint8_t> bytes) {
    // Rust-only: using std::arch::x86_64::__m128i;
    // Rust-only: using std::arch::x86_64::_mm_loadu_si128;
    // Rust-only: using std::arch::x86_64::_mm_movemask_epi8;
    // Rust-only: using std::arch::x86_64::_mm_or_si128;
    auto [chunks, rest] = rusty::detail::deref_if_pointer_like(bytes.template as_chunks<SSE2_CHUNK_SIZE>());
    for (auto&& chunk : rusty::for_in(chunks)) {
        const auto ptr_shadow1 = reinterpret_cast<const uint8_t*>(rusty::as_ptr(chunk));
        const auto mask = [&]() { const auto a1 = _mm_loadu_si128(reinterpret_cast<const __m128i*>(ptr_shadow1));
const auto a2 = _mm_loadu_si128(reinterpret_cast<const __m128i*>(rusty::ptr::add(ptr_shadow1, 16)));
const auto b1 = _mm_loadu_si128(reinterpret_cast<const __m128i*>(rusty::ptr::add(ptr_shadow1, 32)));
const auto b2 = _mm_loadu_si128(reinterpret_cast<const __m128i*>(rusty::ptr::add(ptr_shadow1, 48)));
const auto combined = _mm_or_si128(_mm_or_si128(std::move(a1), std::move(a2)), _mm_or_si128(std::move(b1), std::move(b2)));
return _mm_movemask_epi8(std::move(combined)); }();
        if (rusty::detail::deref_if_pointer_like(mask) != 0) {
            return false;
        }
    }
    return rusty::iter(rest).all([&](auto&& b) { return b.is_ascii(); });
}

/// ASCII test optimized to use the `pmovmskb` instruction on `x86-64`.
///
/// Uses explicit SSE2 intrinsics to prevent LLVM from auto-vectorizing with
/// broken AVX-512 code that extracts mask bits one-by-one.
bool is_ascii(std::span<const uint8_t> bytes) {
    constexpr size_t USIZE_SIZE = sizeof(size_t);
    constexpr size_t NONASCII_MASK = (rusty::detail::deref_if_pointer_like(std::numeric_limits<size_t>::max()) / static_cast<size_t>(255)) * static_cast<size_t>(128);
    std::make_tuple();
}

/// ASCII test optimized to use the `vmskltz.b` instruction on `loongarch64`.
///
/// Other platforms are not likely to benefit from this code structure, so they
/// use SWAR techniques to test for ASCII in `usize`-sized chunks.
bool is_ascii(std::span<const uint8_t> bytes) {
    constexpr size_t CHUNK_SIZE = static_cast<size_t>(32);
    auto i = 0;
    while ((rusty::detail::deref_if_pointer_like(i) + rusty::detail::deref_if_pointer_like(CHUNK_SIZE)) <= rusty::len(bytes)) {
        const auto chunk_end = rusty::detail::deref_if_pointer_like(i) + rusty::detail::deref_if_pointer_like(CHUNK_SIZE);
        auto count = 0;
        while (rusty::detail::deref_if_pointer_like(i) < rusty::detail::deref_if_pointer_like(chunk_end)) {
            rusty::detail::deref_if_pointer_like(count) += static_cast<uint8_t>(bytes[i].is_ascii());
            rusty::detail::deref_if_pointer_like(i) += 1;
        }
        if (rusty::detail::deref_if_pointer_like(count) != (static_cast<uint8_t>(CHUNK_SIZE))) {
            return false;
        }
    }
    auto is_ascii_shadow1 = true;
    while (rusty::detail::deref_if_pointer_like(i) < rusty::len(bytes)) {
        rusty::detail::deref_if_pointer_like(is_ascii_shadow1) &= bytes[i].is_ascii();
        rusty::detail::deref_if_pointer_like(i) += 1;
    }
    return std::move(is_ascii_shadow1);
}


rusty::Option<uint8_t> EscapeAscii::next() {
    using Item = typename EscapeAscii::Item;
    return this->inner.next();
}

std::tuple<size_t, rusty::Option<size_t>> EscapeAscii::size_hint() const {
    using Item = typename EscapeAscii::Item;
    return this->inner.size_hint();
}

template<typename Acc, typename Fold>
auto EscapeAscii::try_fold(Acc init, Fold fold) {
    using Item = typename EscapeAscii::Item;
    using R = std::remove_cvref_t<std::invoke_result_t<Fold&, Acc, uint8_t>>;
    return rusty::try_fold(this->inner, std::move(init), std::move(fold));
}

template<typename Acc, typename Fold>
Acc EscapeAscii::fold(Acc init, Fold fold) {
    using Item = typename EscapeAscii::Item;
    return rusty::fold(this->inner, std::move(init), std::move(fold));
}

rusty::Option<uint8_t> EscapeAscii::last() {
    using Item = typename EscapeAscii::Item;
    return this->next_back();
}

rusty::Option<uint8_t> EscapeAscii::next_back() {
    using Item = typename EscapeAscii::Item;
    return this->inner.next_back();
}

rusty::fmt::Result EscapeAscii::fmt(rusty::fmt::Formatter& f) const {
    using Item = typename EscapeAscii::Item;
    const rusty::SafeFn<bool(uint8_t)> needs_escape = +[](uint8_t b) -> bool {
        return ((((rusty::detail::deref_if_pointer_like(b) > 126) || (rusty::detail::deref_if_pointer_like(b) < 32)) || (rusty::detail::deref_if_pointer_like(b) == static_cast<uint8_t>(92))) || (rusty::detail::deref_if_pointer_like(b) == static_cast<uint8_t>(39))) || (rusty::detail::deref_if_pointer_like(b) == static_cast<uint8_t>(34));
    };
    auto [front, slice, back] = rusty::detail::deref_if_pointer_like(rusty::clone((*this)).inner.into_parts());
    const auto front_shadow1 = front.unwrap_or(EscapeDefault::empty());
    auto* bytes = &(rusty::as_slice(slice.unwrap_or_default()));
    const auto back_shadow1 = back.unwrap_or(EscapeDefault::empty());
    for (auto&& byte : rusty::for_in(front_shadow1)) {
        RUSTY_TRY(f.write_char(static_cast<char32_t>(byte)));
    }
    while (rusty::len(*bytes) > 0) {
        auto prefix = rusty::count(rusty::iter(*bytes).take_while([&](auto&& _closure_ref_param0) {
auto b = rusty::detail::deref_if_pointer_like(_closure_ref_param0);
return !needs_escape(std::move(b));
}));
        auto [prefix_shadow1, remainder] = rusty::detail::deref_if_pointer_like((*bytes).split_at_unchecked(std::move(prefix)));
        auto prefix_shadow2 = rusty::str_runtime::from_utf8_unchecked(std::move(prefix_shadow1));
        RUSTY_TRY(f.write_str(std::move(prefix_shadow2)));
        bytes = &remainder;
        if (auto&& _iflet_scrutinee = (*bytes).first(); _iflet_scrutinee.is_some()) {
            auto&& _iflet_payload = _iflet_scrutinee.unwrap();
            auto&& b = rusty::detail::deref_if_pointer(rusty::detail::deref_if_pointer(_iflet_payload));
            RUSTY_TRY(rusty::write_fmt(f, rusty::to_string(ascii::escape_default(std::move(b)))));
            bytes = &(rusty::slice_from(*bytes, 1));
        }
    }
    for (auto&& byte : rusty::for_in(back_shadow1)) {
        RUSTY_TRY(f.write_char(static_cast<char32_t>(byte)));
    }
    return rusty::fmt::Result::Ok(std::make_tuple());
}

// Extension trait GetDisjointMutIndex lowered to rusty_ext:: free functions
namespace rusty_ext {
    export bool is_in_bounds(const size_t& self_, size_t len) {
        using Self = std::remove_reference_t<decltype(self_)>;
        return self_ < rusty::detail::deref_if_pointer_like(len);
    }

    export bool is_in_bounds(const rusty::range<size_t>& self_, size_t len) {
        using Self = std::remove_reference_t<decltype(self_)>;
        return ((rusty::detail::deref_if_pointer_like(rusty::field_start(self_)) <= rusty::detail::deref_if_pointer_like(rusty::field_end(self_)))) & ((rusty::detail::deref_if_pointer_like(rusty::field_end(self_)) <= rusty::detail::deref_if_pointer_like(len)));
    }

    export bool is_in_bounds(const rusty::range_inclusive<size_t>& self_, size_t len) {
        using Self = std::remove_reference_t<decltype(self_)>;
        return ((rusty::detail::deref_if_pointer_like(rusty::field_start(self_)) <= rusty::detail::deref_if_pointer_like(rusty::field_end(self_)))) & ((rusty::detail::deref_if_pointer_like(rusty::field_end(self_)) < rusty::detail::deref_if_pointer_like(len)));
    }

    export bool is_in_bounds(const rusty::ops::Range<size_t>& self_, size_t len) {
        using Self = std::remove_reference_t<decltype(self_)>;
        return ([&](auto&& __self) -> decltype(auto) { if constexpr (requires { rusty_ext::is_in_bounds(std::forward<decltype(__self)>(__self), std::move(len)); }) { return rusty_ext::is_in_bounds(std::forward<decltype(__self)>(__self), std::move(len)); } else { return rusty_ext::is_in_bounds(rusty::detail::deref_if_pointer_like(std::forward<decltype(__self)>(__self)), rusty::detail::deref_if_pointer_like(std::move(len))); } })(rusty::range::from(self_));
    }

    export bool is_in_bounds(const rusty::ops::RangeInclusive<size_t>& self_, size_t len) {
        using Self = std::remove_reference_t<decltype(self_)>;
        return ([&](auto&& __self) -> decltype(auto) { if constexpr (requires { rusty_ext::is_in_bounds(std::forward<decltype(__self)>(__self), std::move(len)); }) { return rusty_ext::is_in_bounds(std::forward<decltype(__self)>(__self), std::move(len)); } else { return rusty_ext::is_in_bounds(rusty::detail::deref_if_pointer_like(std::forward<decltype(__self)>(__self)), rusty::detail::deref_if_pointer_like(std::move(len))); } })(rusty::range_inclusive::from(self_));
    }

}

