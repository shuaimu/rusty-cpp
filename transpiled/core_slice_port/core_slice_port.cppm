/// Mutable slice iterator.
///
/// This struct is created by the [`iter_mut`] method on [slices].
///
/// # Examples
///
/// Basic usage:
///
/// ```
/// // First, we need a slice to call the `iter_mut` method on:
/// let slice = &mut [1, 2, 3];
///
/// // Then we call `iter_mut` on the slice to get the `IterMut` iterator,
/// // iterate over it and increment each element value:
/// for element in slice.iter_mut() {
///     *element += 1;
/// }
///
/// // We now have "[2, 3, 4]":
/// println!("{slice:?}");
/// ```
///
/// [`iter_mut`]: slice::iter_mut
/// [slices]: slice
export template<typename T>
struct IterMut {
    static constexpr bool MAY_HAVE_SIDE_EFFECT = false;
    /// The pointer to the next element to return, or the past-the-end location
    /// if the iterator is empty.
    ///
    /// This address will be used for all ZST elements, never changed.
    rusty::ptr::NonNull<T> ptr;
    /// For non-ZSTs, the non-null pointer to the past-the-end element.
    ///
    /// For ZSTs, this is `ptr::without_provenance_mut(len)`.
    std::add_pointer_t<T> end_or_len;
    rusty::PhantomData<T&> _marker;

    rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
        return f.debug_tuple("IterMut").field(this->as_slice()).finish();
    }
    static IterMut<T> new_(std::span<T> slice) {
        const auto len = rusty::len(slice);
        rusty::ptr::NonNull<T> ptr_shadow1 = NonNull<std::remove_cvref_t<decltype((slice))>>::from_mut(slice).cast();
        // @unsafe
        {
            auto end_or_len = (T::IS_ZST ? rusty::ptr::without_provenance_mut(std::move(len)) : rusty::ptr::add(rusty::as_ptr(ptr_shadow1), std::move(len)));
            return IterMut<T>{.ptr = std::move(ptr_shadow1), .end_or_len = std::move(end_or_len), ._marker = rusty::PhantomData<T&>{}};
        }
    }
    std::span<T> into_slice() {
        // @unsafe
        {
            return from_raw_parts_mut<std::remove_pointer_t<std::remove_cvref_t<decltype((const_cast<std::add_pointer_t<T>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<T>>>(rusty::as_ptr(this->ptr)))))>>>(const_cast<std::add_pointer_t<T>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<T>>>(rusty::as_ptr(this->ptr))), 0);
        }
    }
    std::span<const T> as_slice() const {
        return this->as_slice();
    }
    std::span<T> as_mut_slice() {
        // @unsafe
        {
            return from_raw_parts_mut<std::remove_pointer_t<std::remove_cvref_t<decltype((const_cast<std::add_pointer_t<T>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<T>>>(rusty::as_ptr(this->ptr)))))>>>(const_cast<std::add_pointer_t<T>>(reinterpret_cast<std::add_pointer_t<std::add_const_t<T>>>(rusty::as_ptr(this->ptr))), 0);
        }
    }
    std::span<const T> as_ref() const {
        return rusty::as_slice((*this));
    }
};

