                    rusty::panicking::assert_failed(std::move(kind), left_val, right_val, rusty::None);
                }
                _m_matched = true;
            }
        }
        if (!!v.spilled()) {
            rusty::panicking::panic("assertion failed: !v.spilled()");
        }
        v.reserve_exact(static_cast<size_t>(256));
        if (!(v.capacity() >= 256)) {
            rusty::panicking::panic("assertion failed: v.capacity() >= 0x100");
        }
        v.push(static_cast<uint8_t>(0));
        v.push(static_cast<uint8_t>(1));
        v.push(static_cast<uint8_t>(2));
        v.push(static_cast<uint8_t>(3));
        v.shrink_to_fit();
        if (!(v.capacity() < 256)) {
            rusty::panicking::panic("assertion failed: v.capacity() < 0x100");
        }
    }

