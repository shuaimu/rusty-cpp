    namespace insert_many_panic {

        void panic_early_at_start() {
            SmallVec<std::array<PanicOnDoubleDrop, 0>> vec = [&]() -> SmallVec<std::array<PanicOnDoubleDrop, 0>> { const auto count = (static_cast<size_t>(0) + static_cast<size_t>(1)) + static_cast<size_t>(1);
auto vec_shadow1 = ::SmallVec<std::array<PanicOnDoubleDrop, 0>>::new_();
return [&]() {
if (count <= vec_shadow1.inline_size()) {
vec_shadow1.push(PanicOnDoubleDrop::new_());
vec_shadow1.push(PanicOnDoubleDrop::new_());
return vec_shadow1;
} else {
return SmallVec<std::array<PanicOnDoubleDrop, 0>>::from_vec(rusty::boxed::into_vec(rusty::boxed::box_new(std::array{PanicOnDoubleDrop::new_(), PanicOnDoubleDrop::new_()})));
