                    auto&& right_val = rusty::detail::deref_if_pointer(std::get<1>(rusty::detail::deref_if_pointer(_m_tuple)));
                    if (!(rusty::detail::deref_if_pointer_like(left_val) == rusty::detail::deref_if_pointer_like(right_val))) {
                        const auto kind = rusty::panicking::AssertKind::Eq;
                        rusty::panicking::assert_failed(std::move(kind), rusty::detail::deref_if_pointer_like(left_val), rusty::detail::deref_if_pointer_like(right_val), rusty::None);
                    }
                    _m_matched = true;
                }
            }
            {
                auto&& _m0_tmp = 3 * PTR_SIZE;
                auto _m0 = &_m0_tmp;
                auto&& _m1_tmp = size_of<SmallVec<std::array<uint8_t, 1>>>();
                auto _m1 = &_m1_tmp;
                auto _m_tuple = std::make_tuple(_m0, _m1);
                bool _m_matched = false;
                if (!_m_matched) {
                    auto&& left_val = rusty::detail::deref_if_pointer(std::get<0>(rusty::detail::deref_if_pointer(_m_tuple)));
                    auto&& right_val = rusty::detail::deref_if_pointer(std::get<1>(rusty::detail::deref_if_pointer(_m_tuple)));
                    if (!(rusty::detail::deref_if_pointer_like(left_val) == rusty::detail::deref_if_pointer_like(right_val))) {
                        const auto kind = rusty::panicking::AssertKind::Eq;
                        rusty::panicking::assert_failed(std::move(kind), rusty::detail::deref_if_pointer_like(left_val), rusty::detail::deref_if_pointer_like(right_val), rusty::None);
                    }
                    _m_matched = true;
                }
            }
            {
                auto&& _m0_tmp = 3 * PTR_SIZE;
                auto _m0 = &_m0_tmp;
                auto&& _m1_tmp = size_of<SmallVec<std::array<uint8_t, rusty::sanitize_array_capacity<PTR_SIZE>()>>>();
                auto _m1 = &_m1_tmp;
                auto _m_tuple = std::make_tuple(_m0, _m1);
                bool _m_matched = false;
                if (!_m_matched) {
                    auto&& left_val = rusty::detail::deref_if_pointer(std::get<0>(rusty::detail::deref_if_pointer(_m_tuple)));
                    auto&& right_val = rusty::detail::deref_if_pointer(std::get<1>(rusty::detail::deref_if_pointer(_m_tuple)));
                    if (!(rusty::detail::deref_if_pointer_like(left_val) == rusty::detail::deref_if_pointer_like(right_val))) {
                        const auto kind = rusty::panicking::AssertKind::Eq;
                        rusty::panicking::assert_failed(std::move(kind), rusty::detail::deref_if_pointer_like(left_val), rusty::detail::deref_if_pointer_like(right_val), rusty::None);
                    }
                    _m_matched = true;
                }
            }
            {
                auto&& _m0_tmp = 4 * PTR_SIZE;
                auto _m0 = &_m0_tmp;
                auto&& _m1_tmp = size_of<SmallVec<std::array<uint8_t, PTR_SIZE + 1>>>();
                auto _m1 = &_m1_tmp;
                auto _m_tuple = std::make_tuple(_m0, _m1);
                bool _m_matched = false;
                if (!_m_matched) {
                    auto&& left_val = rusty::detail::deref_if_pointer(std::get<0>(rusty::detail::deref_if_pointer(_m_tuple)));
                    auto&& right_val = rusty::detail::deref_if_pointer(std::get<1>(rusty::detail::deref_if_pointer(_m_tuple)));
                    if (!(rusty::detail::deref_if_pointer_like(left_val) == rusty::detail::deref_if_pointer_like(right_val))) {
                        const auto kind = rusty::panicking::AssertKind::Eq;
                        rusty::panicking::assert_failed(std::move(kind), rusty::detail::deref_if_pointer_like(left_val), rusty::detail::deref_if_pointer_like(right_val), rusty::None);
                    }
                    _m_matched = true;
                }
            }
        }
    }

    /// This assortment of tests, in combination with miri, verifies we handle UB on fishy arguments
    /// given to SmallVec. Draining and extending the allocation are fairly well-tested earlier, but
    /// `smallvec.insert(usize::MAX, val)` once slipped by!
    ///
    /// All code that indexes into SmallVecs should be tested with such "trivially wrong" args.
    void max_dont_panic() {
        SmallVec<std::array<int32_t, 2>> sv = [&]() -> SmallVec<std::array<int32_t, 2>> { const auto count = static_cast<size_t>(0) + static_cast<size_t>(1);
auto vec = ::SmallVec<std::array<int32_t, 2>>::new_();
return [&]() {
if (count <= vec.inline_size()) {
vec.push(static_cast<int32_t>(0));
return vec;
} else {
return SmallVec<std::array<int32_t, 2>>::from_vec(rusty::boxed::into_vec(rusty::boxed::box_new(std::array{0})));
}
}(); }();
        static_cast<void>(rusty::get(sv, std::numeric_limits<size_t>::max()));
        sv.truncate(std::numeric_limits<size_t>::max());
    }

    void max_remove() {
        SmallVec<std::array<int32_t, 2>> sv = [&]() -> SmallVec<std::array<int32_t, 2>> { const auto count = static_cast<size_t>(0) + static_cast<size_t>(1);
auto vec = ::SmallVec<std::array<int32_t, 2>>::new_();
return [&]() {
if (count <= vec.inline_size()) {
vec.push(static_cast<int32_t>(0));
return vec;
} else {
return SmallVec<std::array<int32_t, 2>>::from_vec(rusty::boxed::into_vec(rusty::boxed::box_new(std::array{0})));
}
}(); }();
        sv.remove(std::numeric_limits<size_t>::max());
    }

    void max_swap_remove() {
        SmallVec<std::array<int32_t, 2>> sv = [&]() -> SmallVec<std::array<int32_t, 2>> { const auto count = static_cast<size_t>(0) + static_cast<size_t>(1);
auto vec = ::SmallVec<std::array<int32_t, 2>>::new_();
return [&]() {
if (count <= vec.inline_size()) {
vec.push(static_cast<int32_t>(0));
return vec;
} else {
return SmallVec<std::array<int32_t, 2>>::from_vec(rusty::boxed::into_vec(rusty::boxed::box_new(std::array{0})));
}
}(); }();
        sv.swap_remove(std::numeric_limits<size_t>::max());
    }

    void test_insert_out_of_bounds() {
        SmallVec<std::array<int32_t, 4>> v = SmallVec<std::array<int32_t, 4>>::new_();
        v.insert(static_cast<size_t>(10), static_cast<int32_t>(6));
    }

}


rusty::fmt::Result CollectionAllocErr::fmt(rusty::fmt::Formatter& f) const {
    return rusty::write_fmt(f, std::format("Allocation error: {0}", rusty::to_debug_string((*this))));
}

CollectionAllocErr CollectionAllocErr::from(rusty::alloc::LayoutErr _arg0) {
    return CollectionAllocErr{CollectionAllocErr_CapacityOverflow{}};
}

SetLenOnDrop SetLenOnDrop::new_(size_t& len) {
    return SetLenOnDrop(len, len);
}

size_t SetLenOnDrop::get() const {
    return this->local_len;
}

void SetLenOnDrop::increment_len(size_t increment) {
    [&]() { static_cast<void>(this->local_len += increment); return std::make_tuple(); }();
}

SetLenOnDrop::~SetLenOnDrop() noexcept(false) {
    if (rusty::mem::consume_forgotten_address(this)) { return; }
    this->len = this->local_len;
}

namespace tests::insert_many_panic {
        PanicOnDoubleDrop PanicOnDoubleDrop::new_() {
            return PanicOnDoubleDrop(rusty::Box<bool>::new_(false));
        }
}

namespace tests::insert_many_panic {
        PanicOnDoubleDrop::~PanicOnDoubleDrop() noexcept(false) {
            if (rusty::mem::consume_forgotten_address(this)) { return; }
            if (!!*(this->dropped)) {
                rusty::panicking::panic("already dropped");
            }
            *(this->dropped) = true;
        }
}

namespace tests::insert_many_panic {
        std::tuple<size_t, rusty::Option<size_t>> BadIter::size_hint() const {
            using Item = typename BadIter::Item;
            return std::make_tuple(this->hint, rusty::Option<size_t>(rusty::None));
        }
}

namespace tests::insert_many_panic {
        rusty::Option<PanicOnDoubleDrop> BadIter::next() {
            using Item = typename BadIter::Item;
            if (this->count == static_cast<size_t>(0)) {
                [&]() -> rusty::Option<PanicOnDoubleDrop> { rusty::panicking::panic("explicit panic"); }();
            }
            [&]() { static_cast<void>(this->count -= 1); return std::make_tuple(); }();
            return rusty::Option<PanicOnDoubleDrop>(PanicOnDoubleDrop::new_());
        }
}

// Extension trait ExtendFromSlice lowered to rusty_ext:: free functions
namespace rusty_ext {
    template<typename T>
    void extend_from_slice(rusty::Vec<T>& self_, std::span<const T> other) {
        using Self = std::remove_reference_t<decltype(self_)>;
        (self_).extend_from_slice(other);
    }

}



