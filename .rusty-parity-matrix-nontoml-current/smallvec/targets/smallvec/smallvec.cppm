    void test_capacity() {
        SmallVec<std::array<uint8_t, 2>> v = SmallVec<std::array<uint8_t, 2>>::new_();
        v.reserve(static_cast<size_t>(1));
        {
            auto&& _m0_tmp = v.capacity();
