    void drain_overflow() {
        SmallVec<std::array<uint8_t, 8>> v = [&]() -> SmallVec<std::array<uint8_t, 8>> { const auto count = static_cast<size_t>(0) + static_cast<size_t>(1);
auto vec = ::SmallVec<std::array<uint8_t, 8>>::new_();
return [&]() {
if (count <= vec.inline_size()) {
vec.push(static_cast<uint8_t>(0));
return vec;
} else {
return SmallVec<std::array<uint8_t, 8>>::from_vec(rusty::boxed::into_vec(rusty::boxed::box_new(std::array{static_cast<uint8_t>(0)})));
}
}(); }();
        v.drain(rusty::range_to_inclusive(std::numeric_limits<size_t>::max()));
    }

