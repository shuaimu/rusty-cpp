    void test_drop_panic_smallvec() {
        struct DropPanic {
            DropPanic() = default;
            DropPanic(const DropPanic&) = default;
            DropPanic(DropPanic&& other) noexcept {
                if (rusty::mem::consume_forgotten_address(&other)) {
                    this->rusty_mark_forgotten();
                    other.rusty_mark_forgotten();
                } else {
                    other.rusty_mark_forgotten();
                }
            }
            DropPanic& operator=(const DropPanic&) = default;
            DropPanic& operator=(DropPanic&& other) noexcept {
                if (this == &other) {
                    return *this;
                }
                this->~DropPanic();
                new (this) DropPanic(std::move(other));
                return *this;
            }
            void rusty_mark_forgotten() noexcept { rusty::mem::mark_forgotten_address(this); }


            ~DropPanic() noexcept(false) {
                if (rusty::mem::consume_forgotten_address(this)) { return; }
                rusty::panicking::panic("drop");
            }
        };
        // Rust-only nested impl block skipped in local scope
        auto v = SmallVec<std::array<DropPanic, 1>>::new_();
        v.push(std::move(DropPanic{}));
    }

    void test_eq() {
        SmallVec<std::array<uint32_t, 2>> a = SmallVec<std::array<uint32_t, 2>>::new_();
        SmallVec<std::array<uint32_t, 2>> b = SmallVec<std::array<uint32_t, 2>>::new_();
        SmallVec<std::array<uint32_t, 2>> c = SmallVec<std::array<uint32_t, 2>>::new_();
        a.push(static_cast<uint32_t>(1));
        a.push(static_cast<uint32_t>(2));
        b.push(static_cast<uint32_t>(1));
        b.push(static_cast<uint32_t>(2));
        c.push(static_cast<uint32_t>(3));
        c.push(static_cast<uint32_t>(4));
        if (!(a == b)) {
            rusty::panicking::panic("assertion failed: a == b");
        }
        if (!(a != c)) {
            rusty::panicking::panic("assertion failed: a != c");
        }
    }

    void test_ord() {
        SmallVec<std::array<uint32_t, 2>> a = SmallVec<std::array<uint32_t, 2>>::new_();
        SmallVec<std::array<uint32_t, 2>> b = SmallVec<std::array<uint32_t, 2>>::new_();
        SmallVec<std::array<uint32_t, 2>> c = SmallVec<std::array<uint32_t, 2>>::new_();
        a.push(static_cast<uint32_t>(1));
        b.push(static_cast<uint32_t>(1));
        b.push(static_cast<uint32_t>(1));
        c.push(static_cast<uint32_t>(1));
        c.push(static_cast<uint32_t>(2));
        if (!(a < b)) {
            rusty::panicking::panic("assertion failed: a < b");
        }
        if (!(b > a)) {
            rusty::panicking::panic("assertion failed: b > a");
        }
        if (!(b < c)) {
            rusty::panicking::panic("assertion failed: b < c");
        }
        if (!(c > b)) {
            rusty::panicking::panic("assertion failed: c > b");
        }
    }

