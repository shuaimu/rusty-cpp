    void shrink_to_fit_unspill() {
        auto vec = SmallVec<std::array<uint8_t, 2>>::from_iter(rusty::range(0, 3));
        vec.pop();
        if (!vec.spilled()) {
            rusty::panicking::panic("assertion failed: vec.spilled()");
        }
        vec.shrink_to_fit();
        if (!!vec.spilled()) {
            rusty::panicking::panic("shrink_to_fit will un-spill if possible");
        }
    }

