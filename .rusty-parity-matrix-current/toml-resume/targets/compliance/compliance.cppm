    void tables_in_arrays() {
        const auto table = from_str<::Table>(rusty::to_string_view("\n[[foo]]\n#…\n[foo.bar]\n#…\n\n[[foo]] # ...\n#…\n[foo.bar]\n#...\n")).unwrap();
        table["foo"][0]["bar"].as_table().unwrap();
        table["foo"][1]["bar"].as_table().unwrap();
    }

    void empty_table() {
        const auto table = from_str<::Table>(rusty::to_string_view("\n[foo]")).unwrap();
        table["foo"].as_table().unwrap();
    }

