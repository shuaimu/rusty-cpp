    /// A spanned value, indicating the range at which it is defined in the source.
    template<typename T>
    struct Spanned {
        /// Byte range
        rusty::range<size_t> span_field;
        /// The spanned value.
        T value;

        Spanned<T> clone() const {
            return Spanned<T>(rusty::clone(this->span_field), rusty::clone(this->value));
        }
        rusty::fmt::Result fmt(rusty::fmt::Formatter& fmt) const {
            return ::de::rusty_ext::fmt(this->get_ref(), fmt);
        }
        static Spanned<T> new_(rusty::range<size_t> range, T value) {
            return Spanned<T>(std::move(range), std::move(value));
        }
        rusty::range<size_t> span() const {
            return rusty::clone(this->span_field);
        }
        T into_inner() {
            return this->value;
        }
        const T& get_ref() const {
            return this->value;
        }
        T& get_mut() {
            return this->value;
        }
        static constexpr std::string_view START_FIELD = std::string_view(::spanned::START_FIELD);
        static constexpr std::string_view END_FIELD = std::string_view(::spanned::END_FIELD);
        static constexpr std::string_view VALUE_FIELD = std::string_view(::spanned::VALUE_FIELD);
        std::string_view borrow() const {
            return this->get_ref();
        }
        const T& as_ref() const {
            return this->get_ref();
        }
        T& as_mut() {
            return this->get_mut();
        }
        bool operator==(const Spanned<T>& other) const {
            return this->value.eq(other.value);
        }
        template<typename H>
        void hash(H& state) const {
            rusty::hash::hash(this->value, state);
        }
        std::partial_ordering operator<=>(const Spanned<T>& other) const {
            return rusty::to_partial_ordering([&]() -> rusty::Option<rusty::cmp::Ordering> {
                return rusty::partial_cmp(this->value, other.value);
            }());
        }
        rusty::cmp::Ordering cmp(const Spanned<T>& other) const {
            return rusty::cmp::cmp(this->value, other.value);
        }
        struct SpannedVisitor {
            rusty::PhantomData<T> _0;
        };
        template<typename D>
        static auto deserialize(D deserializer) -> rusty::Result<Spanned<T>, typename D::Error> {
            static std::array<std::string_view, 3> FIELDS = std::array<std::string_view, 3>{std::string_view(START_FIELD), std::string_view(END_FIELD), std::string_view(VALUE_FIELD)};
            const auto visitor = SpannedVisitor(rusty::PhantomData<std::tuple<>>{});
