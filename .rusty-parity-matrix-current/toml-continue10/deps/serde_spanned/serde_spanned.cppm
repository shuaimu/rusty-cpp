namespace de {

    template<typename T, typename E>
    struct SpannedDeserializer;
    using spanned::Spanned;
    bool is_spanned(std::string_view name);

    // Rust-only trait import marker: using _ = ::de::IntoDeserializer;

    using ::de::value::BorrowedStrDeserializer;

    using spanned::Spanned;

    /// Deserializer / format support for emitting [`Spanned`]
    template<typename T, typename E>
    struct SpannedDeserializer {
        using Error = E;
        rusty::Option<size_t> start;
        rusty::Option<size_t> end;
        rusty::Option<T> value;
        rusty::PhantomData<const std::tuple<>&> _lifetime;
        rusty::PhantomData<E> _error;

        static SpannedDeserializer<T, E> new_(T value, rusty::range<size_t> span) {
            return SpannedDeserializer<T, E>{.start = rusty::Option<size_t>(std::move(span.start)), .end = rusty::Option<size_t>(std::move(span.end_)), .value = rusty::Option<T>(std::move(value)), ._lifetime = rusty::default_value<rusty::PhantomData<const std::tuple<>&>>(), ._error = rusty::default_value<rusty::PhantomData<E>>()};
        }
        template<typename K>
        rusty::Result<rusty::Option<typename K::Value>, Error> next_key_seed(K seed) {
            if (this->start.is_some()) {
                return ::de::rusty_ext::deserialize(seed, std::conditional_t<true, BorrowedStrDeserializer<Error>, K>::new_(rusty::clone(rusty::clone(Spanned<T>::START_FIELD)))).map(rusty::Some);
            } else if (this->end.is_some()) {
                return ::de::rusty_ext::deserialize(seed, std::conditional_t<true, BorrowedStrDeserializer<Error>, K>::new_(rusty::clone(rusty::clone(Spanned<T>::END_FIELD)))).map(rusty::Some);
            } else if (this->value.is_some()) {
                return ::de::rusty_ext::deserialize(seed, std::conditional_t<true, BorrowedStrDeserializer<Error>, K>::new_(rusty::clone(rusty::clone(Spanned<T>::VALUE_FIELD)))).map(rusty::Some);
            } else {
                return rusty::Result<rusty::Option<typename K::Value>, Error>::Ok(rusty::Option<typename K::Value>(rusty::None));
            }
        }
        template<typename V>
        rusty::Result<typename V::Value, Error> next_value_seed(V seed) {
            if (auto&& _iflet_scrutinee = this->start.take(); _iflet_scrutinee.is_some()) {
                decltype(auto) start = _iflet_scrutinee.unwrap();
                return ::de::rusty_ext::deserialize(seed, ::de::value::UsizeDeserializer<E>::new_(std::move(start)));
            } else if (auto&& _iflet_scrutinee = this->end.take(); _iflet_scrutinee.is_some()) {
                decltype(auto) end = _iflet_scrutinee.unwrap();
                return ::de::rusty_ext::deserialize(seed, ::de::value::UsizeDeserializer<E>::new_(std::move(end)));
            } else if (auto&& _iflet_scrutinee = this->value.take(); _iflet_scrutinee.is_some()) {
                decltype(auto) value = _iflet_scrutinee.unwrap();
                return ::de::rusty_ext::deserialize(seed, ([&](auto&& _into_deser_recv) -> decltype(auto) { if constexpr (requires { ::de::value::rusty_ext::into_deserializer<E>(std::forward<decltype(_into_deser_recv)>(_into_deser_recv)); }) { return ::de::value::rusty_ext::into_deserializer<E>(std::forward<decltype(_into_deser_recv)>(_into_deser_recv)); } else { return std::forward<decltype(_into_deser_recv)>(_into_deser_recv).into_deserializer(); } })(std::move(value)));
            } else {
                {
                    [&]() -> rusty::Result<typename V::Value, Error> { rusty::panicking::panic_fmt(std::string("next_value_seed called before next_key_seed")); }();
                }
            }
        }
    };

}

namespace spanned {

    bool is_spanned(std::string_view name) {
        return std::string_view(name) == std::string_view(NAME);
    }

}

namespace de {

    /// Check if deserializing a [`Spanned`]
    bool is_spanned(std::string_view name) {
        return ::spanned::is_spanned(std::string_view(name));
    }

