    void always_works() {
        struct A {
            rusty::HashMap<rusty::String, Value> vals;
        };
        // Algebraic data type
        struct Value_Map {
            rusty::HashMap<rusty::String, rusty::String> _0;
        };
        struct Value_Int {
            int32_t _0;
        };
        using Value = std::variant<Value_Map, Value_Int>;
        const auto Int = [&]( int32_t _0) { return Value_Int{std::forward<int32_t>(_0)};  };
        auto a = A{.vals = rusty::HashMap<rusty::String, Value>()};
        a.vals.insert(rusty::String::from("foo"), Value_Int{0});
        auto sub = rusty::HashMap<rusty::String, rusty::String>();
        sub.insert(rusty::String::from("foo"), rusty::String::from("bar"));
        a.vals.insert(rusty::String::from("bar"), Value_Map{std::move(sub)});
        t(a);
    }

