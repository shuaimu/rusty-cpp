    // Rust-only libtest metadata const skipped: table_type_enum_regression_issue_388 (marker: general::table_type_enum_regression_issue_388, should_panic: no)

    void table_type_enum_regression_issue_388() {
        struct DataFile {
            Compare data;
        };
        // Algebraic data type
        struct Compare_Gt {
            uint32_t _0;
        };
        using Compare = std::variant<Compare_Gt>;
        const auto Gt = [&]( uint32_t _0) { return Compare_Gt{std::forward<uint32_t>(_0)};  };
        const auto dotted_table = "\n        data.Gt = 5\n        ";
        if (!from_str<DataFile>(std::move(dotted_table)).is_ok()) {
            rusty::panicking::panic("assertion failed: crate::from_str::<DataFile>(dotted_table).is_ok()");
        }
        const auto inline_table = "\n        data = { Gt = 5 }\n        ";
        if (!from_str<DataFile>(std::move(inline_table)).is_ok()) {
            rusty::panicking::panic("assertion failed: crate::from_str::<DataFile>(inline_table).is_ok()");
        }
    }

