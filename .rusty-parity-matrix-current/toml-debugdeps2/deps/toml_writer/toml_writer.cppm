namespace value {

    template<typename I, typename K, typename V, typename W>
    rusty::fmt::Result write_toml_inline_table(I iter, W& writer);

    using ::rusty::Cow;
    using ::rusty::Cow_Borrowed;
    using ::rusty::Cow_Owned;

