    rusty::Option<TomlString> TomlStringBuilder::as_literal() const {
        if ((this->metrics.escape_codes || (0 < this->metrics.max_seq_single_quotes)) || this->metrics.newline) {
            return rusty::Option<TomlString>(rusty::None);
        } else {
            return rusty::Option<TomlString>(TomlString(std::string_view(this->decoded), Encoding_LiteralString(), this->metrics.newline));
