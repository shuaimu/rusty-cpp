    enum class Encoding {
        LiteralString,
    BasicString,
    MlLiteralString,
    MlBasicString
    };
    inline constexpr Encoding Encoding_LiteralString() { return Encoding::LiteralString; }
    inline constexpr Encoding Encoding_BasicString() { return Encoding::BasicString; }
    inline constexpr Encoding Encoding_MlLiteralString() { return Encoding::MlLiteralString; }
    inline constexpr Encoding Encoding_MlBasicString() { return Encoding::MlBasicString; }
    inline Encoding clone(const Encoding& self_) {
        return self_;
    }
    inline bool eq(const Encoding& self_, const Encoding& other) {
        const auto __self_discr = rusty::intrinsics::discriminant_value(self_);
        const auto __arg1_discr = rusty::intrinsics::discriminant_value(other);
        return __self_discr == __arg1_discr;
    }
    inline void assert_receiver_is_total_eq(const Encoding& self_) {
    }
    inline rusty::Option<rusty::cmp::Ordering> partial_cmp(const Encoding& self_, const Encoding& other) {
        const auto __self_discr = rusty::intrinsics::discriminant_value(self_);
        const auto __arg1_discr = rusty::intrinsics::discriminant_value(other);
        return rusty::partial_cmp(__self_discr, __arg1_discr);
    }
    inline rusty::cmp::Ordering cmp(const Encoding& self_, const Encoding& other) {
        const auto __self_discr = rusty::intrinsics::discriminant_value(self_);
        const auto __arg1_discr = rusty::intrinsics::discriminant_value(other);
        return rusty::cmp::cmp(__self_discr, __arg1_discr);
    }
    template<typename __H>
    inline void hash(const Encoding& self_, __H& state) {
        const auto __self_discr = rusty::intrinsics::discriminant_value(self_);
        rusty::hash::hash(__self_discr, state);
    }

    struct TomlString {
        std::string_view decoded;
        Encoding encoding;
        bool newline;

        TomlString clone() const;
        bool operator==(const TomlString& other) const;
        void assert_receiver_is_total_eq() const;
        std::partial_ordering operator<=>(const TomlString& other) const;
        rusty::cmp::Ordering cmp(const TomlString& other) const;
        template<typename __H>
