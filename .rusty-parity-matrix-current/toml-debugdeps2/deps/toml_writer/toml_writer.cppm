    }
}

namespace string {
    KeyMetrics KeyMetrics::calculate(std::string_view s) {
        auto metrics = KeyMetrics::new_();
        metrics.unquoted = !rusty::is_empty(s);
        for (auto&& byte : rusty::for_in(rusty::as_bytes(s))) {
            if (!({ auto&& _m = rusty::detail::deref_if_pointer_like(byte); std::optional<bool> _match_value; bool _m_matched = false; if (!_m_matched && ((_m >= static_cast<uint8_t>(97) && _m <= static_cast<uint8_t>(122)) || (_m >= static_cast<uint8_t>(65) && _m <= static_cast<uint8_t>(90)) || (_m >= static_cast<uint8_t>(48) && _m <= static_cast<uint8_t>(57)) || _m == static_cast<uint8_t>(45) || _m == static_cast<uint8_t>(95))) { _match_value.emplace(std::move(true)); _m_matched = true; } if (!_m_matched) { _match_value.emplace(std::move(false)); _m_matched = true; } if (!_m_matched) { rusty::intrinsics::unreachable(); } std::move(_match_value).value(); })) {
                metrics.unquoted = false;
            }
            switch (rusty::detail::deref_if_pointer_like(byte)) {
            case static_cast<uint8_t>(39):
            {
                metrics.single_quotes = true;
                break;
            }
            case static_cast<uint8_t>(34):
            {
                metrics.double_quotes = true;
                break;
            }
            case static_cast<uint8_t>(92):
            {
                metrics.escape = true;
                break;
            }
            case static_cast<uint8_t>(9):
            {
                break;
            }
            default:
            {
                auto&& c = rusty::detail::deref_if_pointer_like(byte);
                if ((c <= 31) || (c == 127)) {
                    metrics.escape_codes = true;
                }
                break;
            }
            }
        }
        return metrics;
    }
}

