            return [&]() -> rusty::Option<rusty::cmp::Ordering> { auto&& _m = rusty::partial_cmp(this->decoded, other.decoded); if (_m.is_some()) { auto&& _mv0 = std::as_const(_m).unwrap(); if (_mv0 == rusty::cmp::Ordering::Equal) { return rusty::partial_cmp(this->encoding, other.encoding); } } if (true) { const auto& cmp = _m; return cmp; } return [&]() -> rusty::Option<rusty::cmp::Ordering> { rusty::intrinsics::unreachable(); }(); }();
        }());
