namespace integer {

    enum class HexCase;
    constexpr HexCase HexCase_Upper();
    constexpr HexCase HexCase_Lower();
    HexCase clone(const HexCase& self_);
    struct Radix;
    struct TomlIntegerFormat;
    template<typename N>
    struct TomlInteger;
    template<typename N, typename W>
    rusty::fmt::Result write_toml_value(N value, const TomlIntegerFormat& format, W& writer);

    enum class HexCase {
        Upper,
    Lower
    };
    inline constexpr HexCase HexCase_Upper() { return HexCase::Upper; }
    inline constexpr HexCase HexCase_Lower() { return HexCase::Lower; }
    inline HexCase clone(const HexCase& self_) {
        return self_;
    }

    namespace fmt = rusty::fmt;
    // Rust-only: using std::fmt::Display;

    // Algebraic data type
    struct Radix_Decimal {};
    struct Radix_Hexadecimal {
        HexCase case_;
    };
    struct Radix_Octal {};
    struct Radix_Binary {};
    Radix_Decimal Decimal();
    Radix_Hexadecimal Hexadecimal(HexCase case_);
    Radix_Octal Octal();
    Radix_Binary Binary();
    struct Radix : std::variant<Radix_Decimal, Radix_Hexadecimal, Radix_Octal, Radix_Binary> {
        using variant = std::variant<Radix_Decimal, Radix_Hexadecimal, Radix_Octal, Radix_Binary>;
        using variant::variant;
        static Radix Decimal() { return Radix{Radix_Decimal{}}; }
        static Radix Hexadecimal(HexCase case_) { return Radix{Radix_Hexadecimal{.case_ = std::forward<decltype(case_)>(case_)}}; }
        static Radix Octal() { return Radix{Radix_Octal{}}; }
        static Radix Binary() { return Radix{Radix_Binary{}}; }


        Radix clone() const;
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const;
    };
    Radix_Decimal Decimal() { return Radix_Decimal{};  }
    Radix_Hexadecimal Hexadecimal(HexCase case_) { return Radix_Hexadecimal{.case_ = std::forward<HexCase>(case_)};  }
    Radix_Octal Octal() { return Radix_Octal{};  }
    Radix_Binary Binary() { return Radix_Binary{};  }

    /// Describes how a TOML integer should be formatted.
    ///
    /// # Example
    ///
    /// ```rust
    /// # #[cfg(feature = "alloc")] {
    /// # use toml_writer::ToTomlValue as _;
    /// let format = toml_writer::TomlIntegerFormat::new().as_hex_lower();
    /// let number = 10;
    /// let number = format.format(number).unwrap_or(toml_writer::TomlInteger::new(number));
    /// let number = number.to_toml_value();
    /// assert_eq!(number, "0xa");
    /// # }
    /// ```
    struct TomlIntegerFormat {
        Radix radix;

        TomlIntegerFormat clone() const;
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const;
        static TomlIntegerFormat new_();
        TomlIntegerFormat as_decimal();
        TomlIntegerFormat as_hex_upper();
        TomlIntegerFormat as_hex_lower();
        TomlIntegerFormat as_octal();
        TomlIntegerFormat as_binary();
        template<typename N>
        rusty::Option<TomlInteger<N>> format(N value);
        static TomlIntegerFormat default_();
    };

    /// Helper struct for formatting TOML integers.
    ///
    /// This may be constructed by calling [`TomlIntegerFormat::format()`].
    template<typename N>
    struct TomlInteger {
        N value;
        TomlIntegerFormat format;

        TomlInteger<N> clone() const {
            return TomlInteger<N>{.value = rusty::clone(this->value), .format = rusty::clone(this->format)};
        }
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const {
            return std::conditional_t<true, rusty::fmt::Formatter, N>::debug_struct_field2_finish(f, "TomlInteger", "value", &this->value, "format", &this->format);
        }
        static TomlInteger<N> new_(N value) {
            return TomlInteger<N>{.value = std::move(value), .format = std::conditional_t<true, TomlIntegerFormat, N>::new_()};
        }
        template<typename W>
        rusty::fmt::Result write_toml_value(W& writer) const {
            return write_toml_value(this->value, this->format, rusty::detail::deref_if_pointer_like(writer));
        }
    };

}

