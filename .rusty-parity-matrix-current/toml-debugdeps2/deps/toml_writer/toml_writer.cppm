            static_cast<void>(::key::rusty_ext::write_toml_key(self_, result));
            return result;
        }

    }

    // Extension trait WriteTomlKey lowered to rusty_ext:: free functions
    namespace rusty_ext {
        template<typename W>
        rusty::fmt::Result write_toml_key(const std::string_view& self_, W& writer) {
            using Self = std::remove_reference_t<decltype(self_)>;
            return ::key::rusty_ext::write_toml_key(std::conditional_t<true, ::TomlKeyBuilder, W>::new_(std::string_view(self_)).as_default(), rusty::detail::deref_if_pointer_like(writer));
        }

        template<typename W>
