        return rusty::fmt::Formatter::debug_struct_field5_finish(f, "ValueMetrics", "max_seq_single_quotes", &this->max_seq_single_quotes, "max_seq_double_quotes", &this->max_seq_double_quotes, "escape_codes", &this->escape_codes, "escape", &this->escape, "newline", &this->newline);
    }
}

namespace string {
    ValueMetrics ValueMetrics::new_() {
        return ValueMetrics{.max_seq_single_quotes = static_cast<uint8_t>(0), .max_seq_double_quotes = static_cast<uint8_t>(0), .escape_codes = false, .escape = false, .newline = false};
    }
}

namespace string {
    ValueMetrics ValueMetrics::calculate(std::string_view s) {
        auto metrics = ValueMetrics::new_();
        int32_t prev_single_quotes = static_cast<int32_t>(0);
        int32_t prev_double_quotes = static_cast<int32_t>(0);
        for (auto&& byte : rusty::for_in(rusty::as_bytes(s))) {
            if (rusty::detail::deref_if_pointer_like(byte) == static_cast<uint8_t>(39)) {
                [&]() { static_cast<void>(prev_single_quotes += 1); return std::make_tuple(); }();
                metrics.max_seq_single_quotes = rusty::max(metrics.max_seq_single_quotes, std::move(prev_single_quotes));
            } else {
                prev_single_quotes = static_cast<int32_t>(0);
            }
            if (rusty::detail::deref_if_pointer_like(byte) == static_cast<uint8_t>(34)) {
                [&]() { static_cast<void>(prev_double_quotes += 1); return std::make_tuple(); }();
                metrics.max_seq_double_quotes = rusty::max(metrics.max_seq_double_quotes, std::move(prev_double_quotes));
            } else {
                prev_double_quotes = static_cast<int32_t>(0);
            }
            switch (rusty::detail::deref_if_pointer_like(byte)) {
            case static_cast<uint8_t>(92):
            {
                metrics.escape = true;
                break;
            }
            case static_cast<uint8_t>(9):
            {
                break;
            }
            case static_cast<uint8_t>(10):
            {
                metrics.newline = true;
                break;
            }
            default:
            {
                auto&& c = rusty::detail::deref_if_pointer_like(byte);
                if ((c <= 31) || (c == 127)) {
                    metrics.escape_codes = true;
                }
                break;
            }
            }
        }
        return metrics;
    }
}

