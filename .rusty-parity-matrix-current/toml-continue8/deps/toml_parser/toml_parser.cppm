    /// Data encoded as TOML
    struct Source {
        std::string_view input_field;

        Source clone() const;
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const;
        bool operator==(const Source& other) const;
        void assert_receiver_is_total_eq() const;
        static Source new_(std::string_view input);
        lexer::Lexer lex() const;
        std::string_view input() const;
        rusty::Option<Raw> get(const auto& span) const;
        rusty::Option<std::string_view> get_raw_str(Span span) const;
    };

    /// Location within the [`Source`]
    struct Span {
        size_t start_field;
        size_t end_field;

        Span clone() const;
        static Span default_();
        bool operator==(const Span& other) const;
        void assert_receiver_is_total_eq() const;
        std::partial_ordering operator<=>(const Span& other) const;
        rusty::cmp::Ordering cmp(const Span& other) const;
        template<typename __H>
        void hash(__H& state) const;
        static Span new_unchecked(size_t start, size_t end);
        bool is_empty() const;
        size_t len() const;
        size_t start() const;
        size_t end() const;
        Span before() const;
        Span after() const;
        Span append(Span after) const;
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const;
        auto operator+(size_t offset) const;
        void operator+=(size_t rhs);
        rusty::Option<Raw> get(const Source& source);
    };

    /// A slice of [`Source`]
    struct Raw {
        std::string_view raw;
        rusty::Option<decoder::Encoding> encoding;
        Span span;

        Raw clone() const;
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const;
        static Raw new_unchecked(std::string_view raw, rusty::Option<decoder::Encoding> encoding, Span span);
        void decode_key(auto& output, auto& error) const;
        ::decoder::scalar::ScalarKind decode_scalar(auto& output, auto& error) const;
        void decode_whitespace(auto& _error) const;
        void decode_comment(auto& error) const;
        void decode_newline(auto& error) const;
        std::string_view as_str() const;
        std::span<const uint8_t> as_bytes() const;
        size_t len() const;
        bool is_empty() const;
    };

