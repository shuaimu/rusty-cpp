namespace lexer {
    Lexer Lexer::new_(std::string_view input) {
        using Item = typename Lexer::Item;
        auto stream = Stream::new_(std::string_view(input));
        if (rusty::starts_with(rusty::as_bytes(input), BOM)) {
            const auto offset = rusty::len(BOM);
            rusty::next_slice(stream, offset);
        }
        return Lexer{.stream = std::move(stream), .eof = false};
    }
}

namespace lexer {
    rusty::Vec<lexer::token::Token> Lexer::into_vec() {
        using Item = typename Lexer::Item;
        const auto capacity = rusty::cmp::min(rusty::len(this->stream), std::numeric_limits<size_t>::max() / rusty::mem::size_of<lexer::token::Token>());
        auto vec = rusty::Vec<lexer::token::Token>::with_capacity(std::move(capacity));
        vec.extend(std::move((*this)));
        return vec;
    }
}

namespace lexer {
    rusty::Option<lexer::token::Token> Lexer::next() {
        using Item = typename Lexer::Item;
        auto&& _let_pat = this->stream.as_bstr().first();
        auto&& peek_byte = rusty::detail::deref_if_pointer((rusty::detail::deref_if_pointer(_let_pat)).unwrap());
        return rusty::Option<lexer::token::Token>(process_token(std::move(rusty::detail::deref_if_pointer_like(peek_byte)), this->stream));
    }
}

