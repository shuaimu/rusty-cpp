        bool push_str(rusty::Cow& self_, std::string_view append) {
            using Self = std::remove_reference_t<decltype(self_)>;
            {
                auto&& _m = self_;
                std::visit(overloaded {
                    [&](std::variant_alternative_t<0, rusty::detail::variant_underlying_type_t<decltype(_m)>>& _v) {
