        }

        bool push_char(rusty::Cow& self_, char32_t append) {
            using Self = std::remove_reference_t<decltype(self_)>;
            rusty::to_mut(self_).push(std::move(append));
            return true;
        }

        void clear(rusty::String& self_) {
            using Self = std::remove_reference_t<decltype(self_)>;
