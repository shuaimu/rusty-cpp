            if (rusty::first(s) != rusty::SomeRef([&]() -> const auto& { static const auto _some_ref_tmp = COMMENT_START_SYMBOL; return _some_ref_tmp; }())) {
                ::error::rusty_ext::report_error(error, ParseError::new_("missing comment start").with_context(Span::new_unchecked(static_cast<size_t>(0), rusty::len(raw))).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 1> _slice_ref_tmp = {::error::Expected{Expected_Literal{"#"}}}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(Span::new_unchecked(static_cast<size_t>(0), static_cast<size_t>(0))));
            }
            for (auto&& _for_item : rusty::for_in(rusty::enumerate(rusty::iter(s).copied()))) {
