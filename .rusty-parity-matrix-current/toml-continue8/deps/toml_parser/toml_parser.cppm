            value(tokens_shadow1, receiver, error);
            eof(tokens_shadow1, receiver, error);
        }

        /// Parse a TOML Document
        ///
        /// Only the order of [`Event`][super::Event]s is validated and not [`Event`][super::Event] content nor semantics like duplicate
        /// keys.
        ///
        /// ```abnf
        /// toml = expression *( newline expression )
        ///
        /// expression =  ws [ comment ]
        /// expression =/ ws keyval ws [ comment ]
        /// expression =/ ws table ws [ comment ]
        ///
        /// ;; Key-Value pairs
        ///
        /// keyval = key keyval-sep val
        /// key = simple-key / dotted-key
        /// val = string / boolean / array / inline-table / date-time / float / integer
        ///
        /// simple-key = quoted-key / unquoted-key
        ///
        /// ;; Quoted and dotted key
        ///
        /// quoted-key = basic-string / literal-string
        /// dotted-key = simple-key 1*( dot-sep simple-key )
        ///
        /// dot-sep   = ws %x2E ws  ; . Period
        /// keyval-sep = ws %x3D ws ; =
        ///
        /// ;; Array
        ///
        /// array = array-open [ array-values ] ws-comment-newline array-close
        ///
        /// array-open =  %x5B ; [
        /// array-close = %x5D ; ]
        ///
        /// array-values =  ws-comment-newline val ws-comment-newline array-sep array-values
        /// array-values =/ ws-comment-newline val ws-comment-newline [ array-sep ]
        ///
        /// array-sep = %x2C  ; , Comma
        ///
        /// ;; Table
        ///
        /// table = std-table / array-table
        ///
        /// ;; Standard Table
        ///
        /// std-table = std-table-open key std-table-close
        ///
        /// ;; Inline Table
        ///
        /// inline-table = inline-table-open [ inline-table-keyvals ] ws-comment-newline inline-table-close
        ///
        /// inline-table-keyvals =  ws-comment-newline keyval ws-comment-newline inline-table-sep inline-table-keyvals
        /// inline-table-keyvals =/ ws-comment-newline keyval ws-comment-newline [ inline-table-sep ]
        ///
        /// ;; Array Table
        ///
        /// array-table = array-table-open key array-table-close
        /// ```
        void document(Stream& tokens, auto& receiver, auto& error) {
            while (true) {
                auto&& _whilelet = rusty::next_token(tokens);
                if (!(_whilelet.is_some())) { break; }
                auto current_token = _whilelet.unwrap();
                switch (current_token.kind()) {
                case TokenKind::LeftSquareBracket:
                {
                    on_table(tokens, std::move(current_token), receiver, error);
                    break;
                }
                case TokenKind::RightSquareBracket:
                {
                    on_missing_std_table(tokens, std::move(current_token), receiver, error);
                    break;
                }
                case TokenKind::LiteralString:
                {
                    on_expression_key(tokens, std::move(current_token), rusty::Option<decoder::Encoding>(decoder::Encoding_LiteralString()), receiver, error);
                    break;
                }
                case TokenKind::BasicString:
                {
                    on_expression_key(tokens, std::move(current_token), rusty::Option<decoder::Encoding>(decoder::Encoding_BasicString()), receiver, error);
                    break;
                }
                case TokenKind::MlLiteralString:
                {
                    on_expression_key(tokens, std::move(current_token), rusty::Option<decoder::Encoding>(decoder::Encoding_MlLiteralString()), receiver, error);
                    break;
                }
                case TokenKind::MlBasicString:
                {
                    on_expression_key(tokens, std::move(current_token), rusty::Option<decoder::Encoding>(decoder::Encoding_MlBasicString()), receiver, error);
                    break;
                }
                case TokenKind::Atom:
                {
                    on_expression_key(tokens, std::move(current_token), rusty::Option<decoder::Encoding>(rusty::None), receiver, error);
                    break;
                }
                case TokenKind::Equals:
                {
                    auto fake_key = current_token.span().before();
                    rusty::Option<decoder::Encoding> encoding = rusty::Option<decoder::Encoding>(rusty::None);
                    ::parser::event::rusty_ext::simple_key(receiver, std::move(fake_key), std::move(encoding), error);
                    on_expression_key_val_sep(tokens, std::move(current_token), receiver, error);
                    break;
                }
                case TokenKind::Dot:
                {
                    on_expression_dot(tokens, std::move(current_token), receiver, error);
                    break;
                }
                case TokenKind::Comma:
                case TokenKind::RightCurlyBracket:
                case TokenKind::LeftCurlyBracket:
                {
                    on_missing_expression_key(tokens, std::move(current_token), receiver, error);
                    break;
                }
                case TokenKind::Whitespace:
                {
                    ::parser::event::rusty_ext::whitespace(receiver, current_token.span(), error);
                    break;
                }
                case TokenKind::Newline:
                {
                    ::parser::event::rusty_ext::newline(receiver, current_token.span(), error);
                    break;
                }
                case TokenKind::Comment:
                {
                    on_comment(tokens, std::move(current_token), receiver, error);
                    break;
                }
                case TokenKind::Eof:
                {
                    break;
                    break;
                }
                }
            }
        }

        /// Start a table from the open token
        ///
        /// This eats to EOL
        ///
        /// ```abnf
        /// ;; Table
        ///
        /// table = std-table / array-table
        ///
        /// ;; Standard Table
        ///
        /// std-table = std-table-open key std-table-close
        ///
        /// ;; Array Table
        ///
        /// array-table = array-table-open key array-table-close
        /// ```
        void on_table(Stream& tokens, const lexer::token::Token& open_token, auto& receiver, auto& error) {
            const auto is_array_table = [&]() {
auto&& _iflet_scrutinee = next_token_if(tokens, [&](auto&& k) {
return ({ auto&& _m = k; std::optional<bool> _match_value; bool _m_matched = false; if (!_m_matched && (_m == TokenKind::LeftSquareBracket)) { _match_value.emplace(std::move(true)); _m_matched = true; } if (!_m_matched) { _match_value.emplace(std::move(false)); _m_matched = true; } if (!_m_matched) { rusty::intrinsics::unreachable(); } std::move(_match_value).value(); });
});
if (_iflet_scrutinee.is_some()) {
auto second_open_token = _iflet_scrutinee.unwrap();
auto span = open_token.span().append(second_open_token.span());
::parser::event::rusty_ext::array_table_open(receiver, std::move(span), error);
return true;
} else {
auto span = open_token.span();
::parser::event::rusty_ext::std_table_open(receiver, std::move(span), error);
return false;
}
}();
            opt_whitespace(tokens, receiver, error);
            const auto valid_key = key(tokens, std::string_view("invalid table"), receiver, error);
            opt_whitespace(tokens, receiver, error);
            auto success = false;
            if (auto&& _iflet_scrutinee = next_token_if(tokens, [&](auto&& k) {
return ({ auto&& _m = k; std::optional<bool> _match_value; bool _m_matched = false; if (!_m_matched && (_m == TokenKind::RightSquareBracket)) { _match_value.emplace(std::move(true)); _m_matched = true; } if (!_m_matched) { _match_value.emplace(std::move(false)); _m_matched = true; } if (!_m_matched) { rusty::intrinsics::unreachable(); } std::move(_match_value).value(); });
}); _iflet_scrutinee.is_some()) {
                decltype(auto) close_token = _iflet_scrutinee.unwrap();
                if (is_array_table) {
                    if (auto&& _iflet_scrutinee = next_token_if(tokens, [&](auto&& k) {
return ({ auto&& _m = k; std::optional<bool> _match_value; bool _m_matched = false; if (!_m_matched && (_m == TokenKind::RightSquareBracket)) { _match_value.emplace(std::move(true)); _m_matched = true; } if (!_m_matched) { _match_value.emplace(std::move(false)); _m_matched = true; } if (!_m_matched) { rusty::intrinsics::unreachable(); } std::move(_match_value).value(); });
}); _iflet_scrutinee.is_some()) {
                        decltype(auto) second_close_token = _iflet_scrutinee.unwrap();
                        auto span = close_token.span().append(second_close_token.span());
                        ::parser::event::rusty_ext::array_table_close(receiver, std::move(span), error);
                        success = true;
                    } else {
                        auto context = open_token.span().append(close_token.span());
                        ::error::rusty_ext::report_error(error, ParseError::new_("unclosed array table").with_context(std::move(context)).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 1> _slice_ref_tmp = {::error::Expected{Expected_Literal{"]"}}}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(close_token.span().after()));
                    }
                } else {
                    ::parser::event::rusty_ext::std_table_close(receiver, close_token.span(), error);
                    success = true;
                }
            } else if (valid_key) {
                const auto last_key_token = tokens.previous_tokens().find([&](auto&& t) { return t.kind() != lexer::token::TokenKind_Whitespace(); }).unwrap_or(open_token);
                auto context = open_token.span().append(last_key_token.span());
                if (is_array_table) {
                    ::error::rusty_ext::report_error(error, ParseError::new_("unclosed array table").with_context(std::move(context)).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 1> _slice_ref_tmp = {::error::Expected{Expected_Literal{"]]"}}}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(last_key_token.span().after()));
                } else {
                    ::error::rusty_ext::report_error(error, ParseError::new_("unclosed table").with_context(std::move(context)).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 1> _slice_ref_tmp = {::error::Expected{Expected_Literal{"]"}}}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(last_key_token.span().after()));
                }
            }
            if (success) {
                ws_comment_newline(tokens, receiver, error);
            } else {
                ignore_to_newline(tokens, receiver, error);
            }
        }

        /// Parse a TOML key
        ///
        /// ```abnf
        /// ;; Key-Value pairs
