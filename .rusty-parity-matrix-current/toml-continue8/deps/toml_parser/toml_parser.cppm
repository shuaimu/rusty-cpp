namespace error {

    struct Expected;
    struct ParseError;
    using source::Span;

    using source::Span;


    // Algebraic data type
    struct Expected_Literal {
        std::string_view _0;
    };
    struct Expected_Description {
        std::string_view _0;
    };
    Expected_Literal Literal(std::string_view _0);
    Expected_Description Description(std::string_view _0);
    struct Expected : std::variant<Expected_Literal, Expected_Description> {
        using variant = std::variant<Expected_Literal, Expected_Description>;
        using variant::variant;
        static Expected Literal(std::string_view _0) { return Expected{Expected_Literal{std::forward<decltype(_0)>(_0)}}; }
        static Expected Description(std::string_view _0) { return Expected{Expected_Description{std::forward<decltype(_0)>(_0)}}; }


        Expected clone() const;
        bool operator==(const Expected& other) const;
        void assert_receiver_is_total_eq() const;
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const;
    };
    Expected_Literal Literal(std::string_view _0) { return Expected_Literal{std::forward<std::string_view>(_0)};  }
    Expected_Description Description(std::string_view _0) { return Expected_Description{std::forward<std::string_view>(_0)};  }


    struct ParseError {
        rusty::Option<::source::Span> context_field;
        ErrorStr description_field;
        rusty::Option<std::span<const Expected>> expected_field;
        rusty::Option<::source::Span> unexpected_field;

        ParseError clone() const;
        bool operator==(const ParseError& other) const;
        void assert_receiver_is_total_eq() const;
        rusty::fmt::Result fmt(rusty::fmt::Formatter& f) const;
        static ParseError new_(const auto& description);
        ParseError with_context(::source::Span context);
        ParseError with_expected(std::span<const Expected> expected);
        ParseError with_unexpected(::source::Span unexpected);
        rusty::Option<::source::Span> context() const;
        std::string_view description() const;
        rusty::Option<std::span<const Expected>> expected() const;
        rusty::Option<::source::Span> unexpected() const;
        ParseError rebase_spans(size_t offset);
    };

    // Extension trait ErrorSink lowered to rusty_ext:: free functions
    namespace rusty_ext {
        template<typename F>
        void report_error(F& self_, ParseError error) {
            using Self = std::remove_reference_t<decltype(self_)>;
            (self_)(std::move(error));
        }

        void report_error(rusty::Option<ParseError>& self_, ParseError error) {
            using Self = std::remove_reference_t<decltype(self_)>;
            self_.get_or_insert(std::move(error));
        }

        void report_error(rusty::Vec<ParseError>& self_, ParseError error) {
            using Self = std::remove_reference_t<decltype(self_)>;
            self_.push(std::move(error));
        }

    }


}

