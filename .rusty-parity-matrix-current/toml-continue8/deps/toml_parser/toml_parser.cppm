        }
}

namespace parser::event {
        bool RecursionGuard::within_depth() const {
            return this->depth <= (static_cast<int64_t>(this->max_depth));
        }
}

namespace parser::event {
        void RecursionGuard::std_table_open(::source::Span span, auto& error) {
            ::parser::event::rusty_ext::std_table_open(this->receiver, std::move(span), error);
        }
}

