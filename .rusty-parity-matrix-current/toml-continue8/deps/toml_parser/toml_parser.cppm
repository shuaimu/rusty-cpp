        /// Parse lexed tokens into [`Event`][super::Event]s
        void parse_document(std::span<const lexer::token::Token> tokens, auto& receiver, auto& error) {
            auto tokens_shadow1 = TokenSlice<std::remove_cvref_t<decltype(*((tokens).begin()))>>::new_(tokens);
            document(tokens_shadow1, receiver, error);
            eof(tokens_shadow1, receiver, error);
        }

        /// Parse lexed tokens into [`Event`][super::Event]s
        void parse_key(std::span<const lexer::token::Token> tokens, auto& receiver, auto& error) {
