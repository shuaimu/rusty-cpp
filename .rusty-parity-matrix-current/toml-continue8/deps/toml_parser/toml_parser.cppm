            case TokenKind::Newline:
            {
                ::parser::event::rusty_ext::newline(receiver, current_token.span(), error);
                break;
            }
            case TokenKind::Eof:
            {
                break;
            }
            }
        }

        void eof(Stream& tokens, auto& receiver, auto& error) {
            auto&& _let_pat = rusty::next_token(tokens);
            auto&& current_token = rusty::detail::deref_if_pointer((rusty::detail::deref_if_pointer(_let_pat)).unwrap());
            switch (current_token.kind()) {
            case TokenKind::Dot:
            case TokenKind::Equals:
            case TokenKind::Comma:
            case TokenKind::LeftSquareBracket:
            case TokenKind::RightSquareBracket:
            case TokenKind::LeftCurlyBracket:
            case TokenKind::RightCurlyBracket:
            case TokenKind::LiteralString:
            case TokenKind::BasicString:
            case TokenKind::MlLiteralString:
            case TokenKind::MlBasicString:
            case TokenKind::Atom:
            case TokenKind::Comment:
            case TokenKind::Whitespace:
            case TokenKind::Newline:
            {
                ::error::rusty_ext::report_error(error, ParseError::new_("unexpected content").with_context(current_token.span()).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 0> _slice_ref_tmp = {}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(current_token.span().before()));
                ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                while (true) {
                    auto&& _whilelet = rusty::next_token(tokens);
                    if (!(_whilelet.is_some())) { break; }
                    auto current_token = _whilelet.unwrap();
                    if (current_token.kind() == lexer::token::TokenKind_Eof()) {
                        continue;
                    }
                    ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                }
                break;
            }
            case TokenKind::Eof:
            {
                break;
            }
            }
        }

        void ignore_to_newline(Stream& tokens, auto& receiver, auto& error) {
            while (true) {
                auto&& _whilelet = rusty::next_token(tokens);
                if (!(_whilelet.is_some())) { break; }
                auto current_token = _whilelet.unwrap();
                switch (current_token.kind()) {
                case TokenKind::Dot:
                case TokenKind::Equals:
                case TokenKind::Comma:
                case TokenKind::LeftSquareBracket:
                case TokenKind::RightSquareBracket:
                case TokenKind::LeftCurlyBracket:
                case TokenKind::RightCurlyBracket:
                case TokenKind::LiteralString:
                case TokenKind::BasicString:
                case TokenKind::MlLiteralString:
                case TokenKind::MlBasicString:
                case TokenKind::Atom:
                {
                    ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                    break;
                }
                case TokenKind::Comment:
                {
                    on_comment(tokens, std::move(current_token), receiver, error);
                    break;
                    break;
                }
                case TokenKind::Whitespace:
                {
                    ::parser::event::rusty_ext::whitespace(receiver, current_token.span(), error);
                    break;
                }
                case TokenKind::Newline:
                {
                    ::parser::event::rusty_ext::newline(receiver, current_token.span(), error);
                    break;
                    break;
                }
                case TokenKind::Eof:
                {
                    break;
                    break;
                }
                }
            }
        }

        /// Don't bother recovering until the matching [`TokenKind`]
        ///
        /// Attempts to ignore nested `[]`, `{}`.
        void ignore_to_value_close(Stream& tokens, lexer::token::TokenKind closing_kind, auto& receiver, auto& error) {
            size_t array_count = static_cast<size_t>(0);
            size_t inline_table_count = static_cast<size_t>(0);
            while (true) {
                auto&& _whilelet = rusty::next_token(tokens);
                if (!(_whilelet.is_some())) { break; }
                auto current_token = _whilelet.unwrap();
                switch (current_token.kind()) {
                case TokenKind::Dot:
                case TokenKind::Equals:
                case TokenKind::Comma:
                case TokenKind::LiteralString:
                case TokenKind::BasicString:
                case TokenKind::MlLiteralString:
                case TokenKind::MlBasicString:
                case TokenKind::Atom:
                {
                    ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                    break;
                }
                case TokenKind::Comment:
                {
                    on_comment(tokens, std::move(current_token), receiver, error);
                    break;
                }
                case TokenKind::Whitespace:
                {
                    ::parser::event::rusty_ext::whitespace(receiver, current_token.span(), error);
                    break;
                }
                case TokenKind::Newline:
                {
                    ::parser::event::rusty_ext::newline(receiver, current_token.span(), error);
                    break;
                }
                case TokenKind::LeftSquareBracket:
                {
                    ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                    [&]() { static_cast<void>(array_count += 1); return std::make_tuple(); }();
                    break;
                }
                case TokenKind::RightSquareBracket:
                {
                    if ((array_count == static_cast<size_t>(0)) && (current_token.kind() == closing_kind)) {
                        ::parser::event::rusty_ext::array_close(receiver, current_token.span(), error);
                        break;
                    } else {
                        ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                        array_count = rusty::saturating_sub(array_count, rusty::detail::deref_if_pointer(1));
                    }
                    break;
                }
                case TokenKind::LeftCurlyBracket:
                {
                    ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                    [&]() { static_cast<void>(inline_table_count += 1); return std::make_tuple(); }();
                    break;
                }
                case TokenKind::RightCurlyBracket:
                {
                    if ((inline_table_count == static_cast<size_t>(0)) && (current_token.kind() == closing_kind)) {
                        ::parser::event::rusty_ext::inline_table_close(receiver, current_token.span(), error);
                        break;
                    } else {
                        ::parser::event::rusty_ext::error(receiver, current_token.span(), error);
                        inline_table_count = rusty::saturating_sub(inline_table_count, rusty::detail::deref_if_pointer(1));
                    }
                    break;
                }
                case TokenKind::Eof:
                {
                    break;
                    break;
                }
                }
            }
        }

        void on_missing_key(Stream& tokens, const lexer::token::Token& token, std::string_view invalid_description, auto& receiver, auto& error) {
            ::error::rusty_ext::report_error(error, ParseError::new_(invalid_description).with_context(token.span()).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 1> _slice_ref_tmp = {::error::Expected{Expected_Description{"key"}}}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(token.span().before()));
            if (token.kind() == lexer::token::TokenKind_Eof()) {
            } else if (token.kind() == lexer::token::TokenKind_Newline()) {
                ::parser::event::rusty_ext::newline(receiver, token.span(), error);
            } else if (token.kind() == lexer::token::TokenKind_Comment()) {
                on_comment(tokens, token, receiver, error);
            } else {
                ::parser::event::rusty_ext::error(receiver, token.span(), error);
            }
        }

        void on_missing_expression_key(Stream& tokens, const lexer::token::Token& token, auto& receiver, auto& error) {
            ::error::rusty_ext::report_error(error, ParseError::new_("invalid key-value pair").with_context(token.span()).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 1> _slice_ref_tmp = {::error::Expected{Expected_Description{"key"}}}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(token.span().before()));
            ::parser::event::rusty_ext::error(receiver, token.span(), error);
            ignore_to_newline(tokens, receiver, error);
        }

        void on_missing_std_table(Stream& tokens, const lexer::token::Token& token, auto& receiver, auto& error) {
            ::error::rusty_ext::report_error(error, ParseError::new_("missing table open").with_context(token.span()).with_expected([&]() -> std::span<const ::error::Expected> { static const std::array<::error::Expected, 1> _slice_ref_tmp = {::error::Expected{Expected_Literal{"["}}}; return std::span<const ::error::Expected>(_slice_ref_tmp); }()).with_unexpected(token.span().before()));
            ::parser::event::rusty_ext::error(receiver, token.span(), error);
            ignore_to_newline(tokens, receiver, error);
        }

        template<typename F>
        rusty::Option<const lexer::token::Token&> next_token_if(Stream& tokens, F pred) {
            return [&]() -> rusty::Option<const lexer::token::Token&> { auto&& _m = tokens.first(); if (_m.is_some()) { auto&& _mv0 = std::as_const(_m).unwrap(); auto&& next = rusty::detail::deref_if_pointer(_mv0); if (pred(next.kind())) { return rusty::next_token(tokens); } } if (true) { return rusty::Option<const lexer::token::Token&>(rusty::None); } return [&]() -> rusty::Option<const lexer::token::Token&> { rusty::intrinsics::unreachable(); }(); }();
        }

        void seek(Stream& stream, ptrdiff_t offset) {
            const auto current = rusty::checkpoint(stream);
            stream.reset_to_start();
            const auto start = rusty::checkpoint(stream);
            const auto old_offset = rusty::offset_from(current, &start);
            const auto new_offset = static_cast<size_t>(rusty::saturating_add(((static_cast<ptrdiff_t>(old_offset))), rusty::detail::deref_if_pointer(std::move(offset))));
            if (new_offset < rusty::eof_offset(stream)) {
                rusty::next_slice(stream, new_offset);
            } else {
                stream.finish();
            }
        }

