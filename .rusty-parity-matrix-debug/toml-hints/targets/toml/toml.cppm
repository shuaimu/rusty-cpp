namespace ser::document {
        template<typename T>
        auto Serializer::serialize_newtype_variant(std::string_view _name, uint32_t _variant_index, std::string_view variant, const T& value) {
            switch (std::conditional_t<true, SerializationStrategy, T>::from(value)) {
            case ::value::Value:
            case SerializationStrategy::ArrayOfTables:
            {
                rusty::String& dst = this->table.body_mut();
                RUSTY_TRY_INTO(dst.key(variant), rusty::Result<ser::document::buffer::Buffer&, ser::error::Error>);
                RUSTY_TRY_INTO(dst.space(), rusty::Result<ser::document::buffer::Buffer&, ser::error::Error>);
                RUSTY_TRY_INTO(dst.keyval_sep(), rusty::Result<ser::document::buffer::Buffer&, ser::error::Error>);
