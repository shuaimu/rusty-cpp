namespace de::error {
        Error Error::new_(rusty::sync::Arc<std::string_view> input, ParseError error) {
            auto message = rusty::String::new_();
            message.push_str(error.description());
            if (auto&& _iflet_scrutinee = error.expected(); _iflet_scrutinee.is_some()) {
                decltype(auto) expected = _iflet_scrutinee.unwrap();
                message.push_str(", expected ");
                if (rusty::is_empty(expected)) {
                    message.push_str("nothing");
                } else {
                    for (auto&& _for_item : rusty::for_in(rusty::enumerate(rusty::iter(expected)))) {
                        auto&& i = std::get<0>(rusty::detail::deref_if_pointer(_for_item));
                        auto&& expected = std::get<1>(rusty::detail::deref_if_pointer(_for_item));
