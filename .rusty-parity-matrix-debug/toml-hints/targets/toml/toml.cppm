namespace de::deserializer::value {
            template<typename V>
            auto ValueDeserializer::deserialize_struct(std::string_view name, std::span<const std::string_view> fields, V visitor) {
                if (::de::is_spanned(name)) {
                    const auto span = rusty::clone(this->span);
                    return visitor.visit_map(super::SpannedDeserializer<auto>::new_(std::move((*this)), std::move(span)));
                }
                if (::de::is_datetime(name)) {
                    auto span = rusty::clone(this->span);
                    if (std::holds_alternative<de::parser::devalue::DeValue_Datetime>(rusty::detail::deref_if_pointer(this->input))) {
                        auto&& d = std::get<de::parser::devalue::DeValue_Datetime>(rusty::detail::deref_if_pointer(this->input))._0;
                        return visitor.visit_map(DatetimeDeserializer<auto>::new_(std::move(d))).map_err([&](auto&& _err) -> de::error::Error { return ([&](de::error::Error e) {
if (e.span().is_none()) {
    e.set_span(rusty::Option<rusty::range<size_t>>(std::move(span)));
}
return e;
}) (std::forward<decltype(_err)>(_err)); });
                    }
                }
                if (this->validate_struct_keys) {
                    auto span = rusty::clone(this->span);
                    RUSTY_TRY_INTO([&]() { auto&& _m = this->input; return std::visit(overloaded { [&](const std::variant_alternative_t<6, rusty::detail::variant_underlying_type_t<decltype(_m)>>& _v) { auto&& values = _v._0; return validate_struct_keys(std::move(values), fields); }, [&](const auto&) { return rusty::Result<typename V::Value, de::error::Error>::Ok(std::make_tuple()); } }, _m); }().map_err([&](de::error::Error e) {
if (e.span().is_none()) {
    e.set_span(rusty::Option<rusty::range<size_t>>(std::move(span)));
}
return e;
}), rusty::Result<typename V::Value, de::error::Error>);
                }
                return this->deserialize_any(std::move(visitor));
            }
}

namespace de::deserializer::value {
            template<typename V>
            auto ValueDeserializer::deserialize_enum(std::string_view name, std::span<const std::string_view> variants, V visitor) {
                auto span = rusty::clone(this->span);
                return [&]() { auto&& _m = this->input; return std::visit(overloaded { [&](std::variant_alternative_t<0, rusty::detail::variant_underlying_type_t<decltype(_m)>>&& _v) -> rusty::Result<typename V::Value, de::error::Error> { auto&& v = _v._0; return visitor.visit_enum(::serde_core::de::rusty_ext::into_deserializer(std::move(v))); }, [&](std::variant_alternative_t<6, rusty::detail::variant_underlying_type_t<decltype(_m)>>&& _v) -> rusty::Result<typename V::Value, de::error::Error> { auto&& v = _v._0; return TableDeserializer<auto>::new_(std::move(v), rusty::clone(span)).deserialize_enum(name, variants, std::move(visitor)); }, [&](auto&&) -> rusty::Result<typename V::Value, de::error::Error> { return rusty::Result<typename V::Value, de::error::Error>::Err(std::conditional_t<true, de::error::Error, V>::custom("wanted string or table", rusty::Option<rusty::range<size_t>>(rusty::clone(span)))); } }, std::move(_m)); }().map_err([&](auto&& _err) -> de::error::Error { return ([&](de::error::Error e) {
if (e.span().is_none()) {
    e.set_span(rusty::Option<rusty::range<size_t>>(std::move(span)));
}
return e;
}) (std::forward<decltype(_err)>(_err)); });
            }
}

