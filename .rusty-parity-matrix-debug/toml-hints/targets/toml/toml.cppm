}

namespace de::deserializer::value {
            ValueDeserializer ValueDeserializer::from(::Spanned<::de::parser::devalue::DeValue> root) {
                auto span = root.span();
                auto root_shadow1 = root.into_inner();
                return ValueDeserializer::with_parts(std::move(root_shadow1), std::move(span));
            }
}

