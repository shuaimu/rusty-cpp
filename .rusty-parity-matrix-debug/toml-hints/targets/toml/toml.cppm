    // Rust-only: using ::de::Deserialize;
    // Rust-only: using ::de::IntoDeserializer;

    using namespace alloc_prelude;

    using value::Array;
    using value::Table;
    using value::Value;
    using namespace value;

    void insert_toml(value::Value& root, std::span<const std::string_view> path, value::Value value) {
        traverse(root, path) = std::move(value);
    }

    void push_toml(value::Value& root, std::span<const std::string_view> path) {
        value::Value& target = traverse(root, path);
        if (!target.is_array()) {
            target = value::Value::Array(Array::new_());
        }
        target.as_array_mut().unwrap().push(value::Value::Table(rusty::make_box(Table::new_())));
    }

    value::Value& traverse(value::Value& root, std::span<const std::string_view> path) {
        value::Value* cur = &(root);
        for (auto&& _for_item : rusty::for_in(rusty::iter(path))) {
            auto&& key = rusty::detail::deref_if_pointer(_for_item);
            auto& cur1 = *cur;
            auto& cur2 = (cur1.is_array() ? cur1.as_array_mut().unwrap().last_mut().unwrap() : cur1);
            if (!cur2.is_table()) {
                cur2 = value::Value{value::Value_Table{rusty::make_box(Table::new_())}};
            }
            if (!cur2.as_table().unwrap().contains_key(std::move(key))) {
                auto empty_shadow1 = value::Value{value::Value_Table{rusty::make_box(Table::new_())}};
                cur2.as_table_mut().unwrap().insert(rusty::to_owned(std::move(key)), std::move(empty_shadow1));
            }
            cur = &(cur2.as_table_mut().unwrap().get_mut(std::move(key)).unwrap());
        }
        return *cur;
    }

}

