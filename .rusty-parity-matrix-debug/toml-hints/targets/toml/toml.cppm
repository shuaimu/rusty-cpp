namespace de::error {
        rusty::fmt::Result Error::fmt(rusty::fmt::Formatter& f) const {
            auto context = false;
            if (auto&& _iflet_scrutinee = std::make_tuple(&this->input, this->span()); (std::get<0>(rusty::detail::deref_if_pointer(_iflet_scrutinee)).is_some() && std::get<1>(rusty::detail::deref_if_pointer(_iflet_scrutinee)).is_some())) {
                auto&& input = std::as_const(std::get<0>(rusty::detail::deref_if_pointer(_iflet_scrutinee))).unwrap();
                auto&& span = std::as_const(std::get<1>(rusty::detail::deref_if_pointer(_iflet_scrutinee))).unwrap();
                context = true;
                auto [line, column] = rusty::detail::deref_if_pointer_like(translate_position(rusty::as_bytes(input), std::move(span.start)));
                const auto line_num = line + 1;
                const auto col_num = column + 1;
                const auto gutter = rusty::len(rusty::to_string(line_num));
                const auto content = rusty::str_runtime::split(input, U'\n').nth(std::move(line)).expect("valid line number");
                const auto highlight_len = rusty::field_end(span) - span.start;
                const auto highlight_len_shadow1 = rusty::min(highlight_len, rusty::saturating_sub(rusty::len(content), rusty::detail::deref_if_pointer(std::move(column))));
                RUSTY_TRY(rusty::write_fmt(f, std::format("TOML parse error at line {0}, column {1}\n", rusty::to_string(line_num), rusty::to_string(col_num))));
                for (auto&& _ : rusty::for_in(rusty::range_inclusive(0, gutter))) {
                    RUSTY_TRY(rusty::write_fmt(f, std::string(" ")));
                }
                RUSTY_TRY(rusty::write_fmt(f, std::string("|\n")));
                RUSTY_TRY(rusty::write_fmt(f, std::format("{0} | ", rusty::to_string(line_num))));
                RUSTY_TRY(rusty::write_fmt(f, std::format("{0}\n", rusty::to_string(content))));
                for (auto&& _ : rusty::for_in(rusty::range_inclusive(0, gutter))) {
                    RUSTY_TRY(rusty::write_fmt(f, std::string(" ")));
                }
                RUSTY_TRY(rusty::write_fmt(f, std::string("|")));
                for (auto&& _ : rusty::for_in(rusty::range_inclusive(0, column))) {
                    RUSTY_TRY(rusty::write_fmt(f, std::string(" ")));
                }
                RUSTY_TRY(rusty::write_fmt(f, std::string("^")));
                for (auto&& _ : rusty::for_in(rusty::range(1, highlight_len_shadow1))) {
                    RUSTY_TRY(rusty::write_fmt(f, std::string("^")));
                }
                RUSTY_TRY(rusty::write_fmt(f, std::string("\n")));
            }
            RUSTY_TRY(rusty::write_fmt(f, std::format("{0}\n", rusty::to_string(this->message_field))));
            if (!context && !rusty::is_empty(this->keys)) {
                RUSTY_TRY(rusty::write_fmt(f, std::format("in `{0}`\n", rusty::to_string(this->keys.join(".")))));
            }
            return rusty::fmt::Result::Ok(std::make_tuple());
        }
}

