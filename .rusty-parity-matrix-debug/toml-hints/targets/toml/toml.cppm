}

namespace ser::document::array {
            template<typename T>
            auto SerializeDocumentTupleVariant::serialize_field(const T& value) {
                rusty::String& dst = this->table.body_mut();
                if (this->style.multiline_array) {
                    RUSTY_TRY_INTO(dst.newline(), rusty::Result<std::tuple<>, ser::document::Error>);
                    RUSTY_TRY_INTO(rusty::write_fmt(dst, std::string("    ")), rusty::Result<std::tuple<>, ser::document::Error>);
                } else {
                    if (this->seen_value) {
                        RUSTY_TRY_INTO(dst.val_sep(), rusty::Result<std::tuple<>, ser::document::Error>);
                        RUSTY_TRY_INTO(dst.space(), rusty::Result<std::tuple<>, ser::document::Error>);
                    }
                }
                this->seen_value = true;
                RUSTY_TRY_INTO(([&](auto&& __self, auto&& __serializer) -> decltype(auto) { if constexpr (requires { std::forward<decltype(__self)>(__self).serialize(std::forward<decltype(__serializer)>(__serializer)); }) { return std::forward<decltype(__self)>(__self).serialize(std::forward<decltype(__serializer)>(__serializer)); } else { return ::ser::impls::rusty_ext::serialize(std::forward<decltype(__self)>(__self), std::forward<decltype(__serializer)>(__serializer)); } })(value, std::conditional_t<true, ValueSerializer, T>::with_style(dst, this->style)), rusty::Result<std::tuple<>, ser::document::Error>);
                if (this->style.multiline_array) {
                    RUSTY_TRY_INTO(dst.val_sep(), rusty::Result<std::tuple<>, ser::document::Error>);
                }
                return rusty::Result<std::tuple<>, ser::document::Error>::Ok(std::make_tuple());
            }
}

namespace ser::document::array {
            rusty::Result<ser::document::buffer::Buffer&, ser::document::Error> SerializeDocumentTupleVariant::end() {
                rusty::String& dst = this->table.body_mut();
                if (this->style.multiline_array && this->seen_value) {
                    RUSTY_TRY_INTO(dst.newline(), rusty::Result<ser::document::buffer::Buffer&, ser::document::Error>);
                }
                RUSTY_TRY_INTO(dst.close_array(), rusty::Result<ser::document::buffer::Buffer&, ser::document::Error>);
                RUSTY_TRY_INTO(dst.newline(), rusty::Result<ser::document::buffer::Buffer&, ser::document::Error>);
                this->buf.push(std::move(this->table));
                return rusty::Result<ser::document::buffer::Buffer&, ser::document::Error>::Ok(std::move(this->buf));
            }
}

