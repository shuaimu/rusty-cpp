namespace de::deserializer::value {
            rusty::Result<ValueDeserializer, de::error::Error> ValueDeserializer::parse(std::string_view raw) {
                auto input = RUSTY_TRY_INTO(DeValue::parse(std::string_view(raw)), rusty::Result<ValueDeserializer, de::error::Error>);
                auto span = input.span();
                auto input_shadow1 = input.into_inner();
                return rusty::Result<ValueDeserializer, de::error::Error>::Ok(ValueDeserializer::with_parts(std::move(input_shadow1), std::move(span)));
            }
}

namespace de::deserializer::value {
            rusty::Result<ValueDeserializer, de::error::Error> ValueDeserializer::new_(std::string_view raw) {
