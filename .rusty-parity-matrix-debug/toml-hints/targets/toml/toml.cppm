                RUSTY_TRY_INTO(dst.keyval_sep(), rusty::Result<SerializeDocumentTupleVariant, ser::document::Error>);
                RUSTY_TRY_INTO(dst.space(), rusty::Result<SerializeDocumentTupleVariant, ser::document::Error>);
                RUSTY_TRY_INTO(dst.open_array(), rusty::Result<SerializeDocumentTupleVariant, ser::document::Error>);
                return rusty::Result<SerializeDocumentTupleVariant, ser::document::Error>::Ok(SerializeDocumentTupleVariant{.buf = buf, .table = std::move(table), .seen_value = false, .style = std::move(style)});
