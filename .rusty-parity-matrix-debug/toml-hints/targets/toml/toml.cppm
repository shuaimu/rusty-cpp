namespace ser::document::buffer {
            rusty::fmt::Result Buffer::fmt(rusty::fmt::Formatter& f) const {
                auto tables = rusty::filter(rusty::filter_map(this->tables, [&](auto&& t) { return t.as_ref(); }), [&](auto&& t) { return required_table(std::move(t)); });
                if (auto&& _iflet_scrutinee = tables.next(); rusty::detail::option_has_value(_iflet_scrutinee)) {
                    auto&& _iflet_take = _iflet_scrutinee;
                    auto table = rusty::detail::option_take_value(_iflet_take);
                    RUSTY_TRY(::de::rusty_ext::fmt(table, f));
                }
                for (auto&& table : rusty::for_in(tables)) {
                    RUSTY_TRY(f.newline());
                    RUSTY_TRY(::de::rusty_ext::fmt(table, f));
                }
                return rusty::fmt::Result::Ok(std::make_tuple());
            }
}

