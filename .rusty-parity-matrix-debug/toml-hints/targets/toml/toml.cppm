namespace ser::document::buffer {
            rusty::fmt::Result Table::fmt(rusty::fmt::Formatter& f) const {
                if (this->key.is_some()) {
                    decltype(auto) key = this->key.unwrap();
                    if (this->array) {
                        RUSTY_TRY(f.open_array_of_tables_header());
                    } else {
                        RUSTY_TRY(f.open_table_header());
                    }
                    auto key_shadow1 = rusty::iter(key);
                    if (auto&& _iflet_scrutinee = key_shadow1.next(); rusty::detail::option_has_value(_iflet_scrutinee)) {
                        auto&& _iflet_take = _iflet_scrutinee;
                        auto key_shadow1 = rusty::detail::option_take_value(_iflet_take);
                        RUSTY_TRY(rusty::write_fmt(f, std::format("{0}", rusty::to_string(key_shadow1))));
                    }
                    auto _for_iter = key_shadow1;
                    for (auto&& key : rusty::for_in(_for_iter)) {
                        RUSTY_TRY(f.key_sep());
                        RUSTY_TRY(rusty::write_fmt(f, std::format("{0}", rusty::to_string(key))));
                    }
                    if (this->array) {
                        RUSTY_TRY(f.close_array_of_tables_header());
                    } else {
                        RUSTY_TRY(f.close_table_header());
                    }
                    RUSTY_TRY(f.newline());
                }
                RUSTY_TRY(::de::rusty_ext::fmt(this->body, f));
                return rusty::fmt::Result::Ok(std::make_tuple());
            }
}

