    template<typename T>
    struct ValueSerializeVariant {
        using Ok = std::conditional_t<true, Value, T>;
        using Error = std::conditional_t<true, ::ser::error::Error, T>;
        std::string_view variant;
        T inner;

        static ValueSerializeVariant<T> tuple(std::string_view variant, size_t len) {
            return ValueSerializeVariant<T>{.variant = std::string_view(variant), .inner = ValueSerializeVec(rusty::Vec<Value>::with_capacity(std::move(len)))};
        }
        static ValueSerializeVariant<T> struct_(std::string_view variant, size_t len) {
            return ValueSerializeVariant<T>{.variant = std::string_view(variant), .inner = ValueSerializeMap{.ser = rusty::make_box(std::conditional_t<true, ::table::SerializeMap, T>::with_capacity(std::move(len)))}};
        }
        auto serialize_field(const T& value) {
            return this->inner.serialize_element(value);
        }
        rusty::Result<Ok, Error> end() {
            auto inner = RUSTY_TRY_INTO((std::move(this->inner)).end(), rusty::Result<Ok, Error>);
            auto table_shadow1 = std::conditional_t<true, Table, T>::new_();
            table_shadow1.insert(rusty::String::from(std::move(this->variant)), std::move(inner));
            return rusty::Result<Ok, Error>::Ok(std::conditional_t<true, Value, T>::Table(std::move(table_shadow1)));
        }
        auto serialize_field(std::string_view key, const T& value) {
            return this->inner.serialize_field(key, value);
        }
    };

