:custom("floating-point number overflowed", rusty::Option<rusty::range<size_t>>(rusty::None)))); }(); }, [&](std::variant_alternative_t<3, rusty::detail::variant_underlying_type_t<decltype(_m)>>&& _v) -> rusty::Result<typename V::Value, de::error::Error> { auto&& v = _v._0; return visitor.visit_bool(std::move(v)); }, [&](std::variant_alternative_t<4, rusty::detail::variant_underlying_type_t<decltype(_m)>>&& _v) -> rusty::Result<typename V::Value, de::error::Error> { auto&& v = _v._0; return visitor.visit_map(DatetimeDeserializer<auto>::new_(std::move(v))); }, [&](std::variant_alternative_t<5, rusty::detail::variant_underlying_type_t<decltype(_m)>>&& _v) -> rusty::Result<typename V::Value, de::error::Error> { auto&& v = rusty::detail::deref_if_pointer_like(_v._0); return ArrayDeserializer<auto>::new_(std::move(v), rusty::clone(span)).deserialize_any(std::move(visitor)); }, [&](std::variant_alternative_t<6, rusty::detail::variant_underlying_type_t<decltype(_m)>>&& _v) -> rusty::Result<typename V::Value, de::error::Error> { auto&& v = _v._0; return TableDeserializer<auto>::new_(std::move(v), rusty::clone(span)).deserialize_any(std::move(visitor)); } }, std::move(_m)); }().map_err([&](auto&& _err) -> de::error::Error { return ([&](de::error::Error e) {
