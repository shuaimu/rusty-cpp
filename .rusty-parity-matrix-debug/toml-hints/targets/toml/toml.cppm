        namespace key {

            /// ```abnf
            /// key = simple-key / dotted-key
            /// dotted-key = simple-key 1*( dot-sep simple-key )
            /// ```
            std::tuple<rusty::Vec<::Spanned<::de::parser::devalue::DeString>>, rusty::Option<::Spanned<::de::parser::devalue::DeString>>> on_key(const ::parser::Event& key_event, ::de::parser::prelude::Input& input, Source source, auto& errors) {
                auto result_path = rusty::Vec<::Spanned<::de::parser::devalue::DeString>>::new_();
                rusty::Option<::Spanned<::de::parser::devalue::DeString>> result_key = rusty::Option<::Spanned<::de::parser::devalue::DeString>>(rusty::None);
                auto state = State::new_(key_event);
                if (more_key(input)) {
                    while (true) {
                        auto&& _whilelet = rusty::next_token(input);
                        if (!(_whilelet.is_some())) { break; }
                        auto event = _whilelet.unwrap();
                        switch (event.kind()) {
                        case EventKind::StdTableOpen:
                        case EventKind::ArrayTableOpen:
                        case EventKind::InlineTableOpen:
                        case EventKind::InlineTableClose:
                        case EventKind::ArrayOpen:
                        case EventKind::ArrayClose:
                        case EventKind::Scalar:
                        case EventKind::ValueSep:
                        case EventKind::Comment:
                        case EventKind::Newline:
                        case EventKind::KeyValSep:
                        case EventKind::StdTableClose:
                        case EventKind::ArrayTableClose:
                        case EventKind::Error:
                        {
                            continue;
                            break;
                        }
                        case EventKind::SimpleKey:
                        {
                            state.current_key = rusty::Some(rusty::detail::deref_if_pointer_like(event));
                            if (!more_key(input)) {
                                break;
                            }
                            break;
                        }
                        case EventKind::Whitespace:
                        {
                            state.whitespace(std::move(event));
                            break;
                        }
                        case EventKind::KeySep:
                        {
                            state.close_key(result_path, result_key, std::move(source), errors);
                            break;
                        }
                        }
                    }
                }
                state.close_key(result_path, result_key, std::move(source), errors);
                if (de::parser::LIMIT <= (static_cast<uint32_t>(rusty::len(result_path)))) {
                    errors->report_error(ParseError::new_("recursion limit"));
                    return std::make_tuple(rusty::Vec<::Spanned<::de::parser::devalue::DeString>>::new_(), rusty::Option<::Spanned<::de::parser::devalue::DeString>>(rusty::None));
                }
                return std::make_tuple(std::move(result_path), std::move(result_key));
            }

            bool more_key(const ::de::parser::prelude::Input& input) {
                const auto first = input.get(0).map([&](auto&& e) { return e.kind(); });
                const auto second = input.get(1).map([&](auto&& e) { return e.kind(); });
                if (first == rusty::Some(EventKind::KeySep)) {
                    return true;
                } else if ((first == rusty::Some(EventKind::Whitespace)) && (second == rusty::Some(EventKind::KeySep))) {
                    return true;
                } else {
                    return false;
                }
            }

        }

        namespace array {

            /// ```abnf
            /// ;; Array
            ///
            /// array = array-open array-values array-close
            /// array-values =  ws-comment-newline val ws-comment-newline array-sep array-values
            /// array-values =/ ws-comment-newline val ws-comment-newline [ array-sep ]
            /// ```
            ::Spanned<::de::parser::devalue::DeValue> on_array(const ::parser::Event& open_event, ::de::parser::prelude::Input& input, Source source, auto& errors) {
                auto result = DeArray::new_();
                auto close_span = open_event.span();
                auto state = State::default_();
                state.open(open_event);
                while (true) {
                    auto&& _whilelet = rusty::next_token(input);
                    if (!(_whilelet.is_some())) { break; }
                    auto event = _whilelet.unwrap();
                    close_span = event.span();
                    switch (event.kind()) {
                    case EventKind::StdTableOpen:
                    case EventKind::ArrayTableOpen:
                    case EventKind::InlineTableClose:
                    case EventKind::SimpleKey:
                    case EventKind::KeySep:
                    case EventKind::KeyValSep:
                    case EventKind::StdTableClose:
                    case EventKind::ArrayTableClose:
                    {
                        break;
                        break;
                    }
                    case EventKind::Error:
                    {
                        continue;
                        break;
                    }
                    case EventKind::InlineTableOpen:
                    {
                        auto value_shadow1 = inline_table::on_inline_table(std::move(event), input, std::move(source), errors);
                        state.capture_value(std::move(event), std::move(value_shadow1));
                        break;
                    }
                    case EventKind::ArrayOpen:
                    {
                        auto value_shadow1 = on_array(std::move(event), input, std::move(source), errors);
                        state.capture_value(std::move(event), std::move(value_shadow1));
