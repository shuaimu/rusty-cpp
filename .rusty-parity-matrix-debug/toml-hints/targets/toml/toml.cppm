        static Entry<K, V> Vacant(VacantEntry<K, V> _0) { return Entry<K, V>{Entry_Vacant<K, V>{std::forward<decltype(_0)>(_0)}}; }
        static Entry<K, V> Occupied(OccupiedEntry<K, V> _0) { return Entry<K, V>{Entry_Occupied<K, V>{std::forward<decltype(_0)>(_0)}}; }


