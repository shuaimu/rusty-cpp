            }
}

namespace de::deserializer::table {
            template<typename V>
            auto TableDeserializer::deserialize_struct(std::string_view name, std::span<const std::string_view> _fields, V visitor) {
                if (::de::is_spanned(name)) {
                    const auto span = rusty::clone(this->span);
                    return visitor.visit_map(super::SpannedDeserializer<auto>::new_(std::move((*this)), std::move(span)));
                }
                return this->deserialize_any(std::move(visitor));
            }
}

namespace de::deserializer::table {
            template<typename V>
            auto TableDeserializer::deserialize_enum(std::string_view _name, std::span<const std::string_view> _variants, V visitor) {
                if (rusty::is_empty(this->items)) {
                    return rusty::Result<typename V::Value, de::error::Error>::Err(std::conditional_t<true, de::error::Error, V>::custom("wanted exactly 1 element, found 0 elements", rusty::Option<rusty::range<size_t>>(std::move(this->span))));
                } else if (rusty::len(this->items) != 1) {
                    return rusty::Result<typename V::Value, de::error::Error>::Err(std::conditional_t<true, de::error::Error, V>::custom("wanted exactly 1 element, more than 1 element", rusty::Option<rusty::range<size_t>>(std::move(this->span))));
                } else {
                    return visitor.visit_enum(std::conditional_t<true, TableMapAccess, V>::new_(std::move((*this))));
                }
            }
}

