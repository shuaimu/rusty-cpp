    /// struct Database {
    ///     ip: String,
    ///     port: Vec<u16>,
    ///     connection_max: u32,
    ///     enabled: bool,
    /// }
    ///
    /// let config = Config {
    ///     database: Database {
    ///         ip: "192.168.1.1".to_string(),
    ///         port: vec![8001, 8002, 8003],
    ///         connection_max: 5000,
