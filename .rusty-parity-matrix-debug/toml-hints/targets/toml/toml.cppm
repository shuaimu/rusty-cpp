        template<typename S>
        struct TomlSink {
            Source source;
            rusty::Option<rusty::sync::Arc<std::string_view>> input;
            S sink;

            static TomlSink<S> new_(Source source) {
                return TomlSink<S>{.source = std::move(source), .input = rusty::Option<rusty::sync::Arc<std::string_view>>(rusty::None), .sink = rusty::default_value<S>()};
            }
            S into_inner() {
                return this->sink;
            }
            void report_error(ParseError error) {
                if (this->sink.is_none()) {
                    const auto input = this->input.get_or_insert_with([&]() { return rusty::from_into<rusty::sync::Arc<std::remove_cvref_t<decltype((this->source.input()))>>>(this->source.input()); });
                    auto error_shadow1 = TomlSink<S>::new_(rusty::clone(input), std::move(error));
                    this->sink = rusty::Option<TomlSink<S>>(std::move(error_shadow1));
                }
            }
        };

