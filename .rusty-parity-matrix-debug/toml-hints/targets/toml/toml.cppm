            return [&]() { auto&& _m = (*this); return std::visit(overloaded { [&](const Entry_Vacant<K, V>& _v) -> const K& { const auto& e = _v._0; return e.key(); }, [&](const Entry_Occupied<K, V>& _v) -> const K& { const auto& e = _v._0; return e.key(); } }, _m); }();
