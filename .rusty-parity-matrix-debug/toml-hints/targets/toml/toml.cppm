namespace ser::document::array {
            rusty::Result<SerializeDocumentTupleVariant, ser::document::Error> SerializeDocumentTupleVariant::tuple(ser::document::buffer::Buffer& buf, ser::document::buffer::Table table, std::string_view variant, size_t _len, ser::document::style::Style style) {
                rusty::String& dst = table.body_mut();
