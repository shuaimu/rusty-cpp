            }
            auto span = error.unexpected().map([&](auto&& span) { return rusty::range(span.start(), span.end()); });
            return Error(std::move(message), rusty::Option<rusty::sync::Arc<std::string_view>>(std::move(input)), rusty::Vec<rusty::String>::new_(), std::move(span));
        }
}

